-- ==========================================
-- TÊN SẢN PHẨM: MinT Hook Bypass Hub (Bản Kavo Siêu Nhẹ)
-- TÁC GIẢ: Em trai làm mướn cho bà chị MinT
-- ==========================================

-- Gọi thư viện Kavo UI (Load siêu tốc)
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

-- Tạo Cửa sổ (Có các theme: DarkTheme, LightTheme, BloodTheme, Sentinel)
local Window = Library.CreateLib("MinT Hook Bypass Hub 🎯", "DarkTheme")

-- ==========================================
-- TẠO TAB CHIẾN ĐẤU
-- ==========================================
local CombatTab = Window:NewTab("⚔️ Chiến Đấu")

-- SECTION 1: HITBOX
local HitboxSection = CombatTab:NewSection("Mở Rộng Hitbox Địch")

_G.HitboxStatus = false
_G.HitboxSize = 20

HitboxSection:NewToggle("Kích Hoạt Hitbox", "Phóng to khối cơ thể kẻ địch để dễ móc", function(state)
    _G.HitboxStatus = state
    if not state then
        -- Tắt đi thì thu nhỏ lại như cũ
        for _, v in pairs(game:GetService("Players"):GetPlayers()) do
            if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                v.Character.HumanoidRootPart.Transparency = 1
            end
        end
    end
end)

HitboxSection:NewSlider("Kích Thước Hitbox", "Tùy chỉnh độ to (Tối đa 50)", 50, 5, function(s)
    _G.HitboxSize = s
end)

-- SECTION 2: AUTO DODGE
local DodgeSection = CombatTab:NewSection("Hệ Thống Né Tránh")

_G.AutoDodge = false

DodgeSection:NewToggle("Tự Động Né Móc", "Dịch chuyển ngang 15m khi phát hiện móc", function(state)
    _G.AutoDodge = state
end)

-- ==========================================
-- TẠO TAB HIỂN THỊ
-- ==========================================
local VisualTab = Window:NewTab("👁️ Hiển Thị")
local ESPSection = VisualTab:NewSection("Nhìn Xuyên Tường")

_G.ESPStatus = false

ESPSection:NewToggle("Bật ESP (Địch/Ta)", "Xanh lá: Đồng đội | Đỏ: Kẻ thù", function(state)
    _G.ESPStatus = state
    if not state then
        -- Dọn dẹp viền sáng khi tắt
        for _, v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("Highlight") and v.Name == "MinTESP" then
                v:Destroy()
            end
        end
    end
end)

-- ==========================================
-- CÁC VÒNG LẶP XỬ LÝ NGẦM
-- ==========================================

-- 1. Vòng lặp Hitbox
task.spawn(function()
    while task.wait(1) do
        if _G.HitboxStatus then
            pcall(function()
                for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                    if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        v.Character.HumanoidRootPart.Transparency = 0.6
                        v.Character.HumanoidRootPart.CanCollide = false
                    end
                end
            end)
        end
    end
end)

-- 2. Vòng lặp Auto Dodge
game.Workspace.ChildAdded:Connect(function(child)
    if _G.AutoDodge then
        pcall(function()
            -- Bắt sự kiện sinh ra vật thể bay tên là Hook hoặc Grapple
            if child.Name == "Hook" or child.Name == "Grapple" then
                local player = game.Players.LocalPlayer
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    -- Dịch chuyển né sang một bên
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(15, 0, 0)
                end
            end
        end)
    end
end)

-- 3. Vòng lặp ESP
task.spawn(function()
    while task.wait(0.5) do
        if _G.ESPStatus then
            pcall(function()
                for _, player in pairs(game:GetService("Players"):GetPlayers()) do
                    if player ~= game:GetService("Players").LocalPlayer and player.Character then
                        if not player.Character:FindFirstChild("MinTESP") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "MinTESP"
                            highlight.Parent = player.Character
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            
                            if player.Team == game:GetService("Players").LocalPlayer.Team then
                                highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Đồng đội
                            else
                                highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Kẻ thù
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- Chú ý: Kavo UI có nút thu gọn menu mặc định là phím RightControl (Ctrl phải).
