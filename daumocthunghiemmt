-- ==========================================
-- LOGIC HITBOX (Đã sửa lỗi vật lý)
-- ==========================================
_G.HitboxStatus = false
HitboxBtn.MouseButton1Click:Connect(function()
    _G.HitboxStatus = not _G.HitboxStatus
    HitboxBtn.Text = "Hitbox: " .. (_G.HitboxStatus and "BẬT" or "TẮT")
    HitboxBtn.BackgroundColor3 = _G.HitboxStatus and Color3.fromRGB(46, 139, 87) or Color3.fromRGB(60, 60, 65)
    
    if not _G.HitboxStatus then
        for _, v in pairs(game:GetService("Players"):GetPlayers()) do
            if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                v.Character.HumanoidRootPart.Transparency = 1
                v.Character.HumanoidRootPart.CanCollide = true
            end
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        if _G.HitboxStatus then
            pcall(function()
                for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                    if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(20, 20, 20)
                        v.Character.HumanoidRootPart.Transparency = 0.6
                        v.Character.HumanoidRootPart.CanCollide = false
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- LOGIC AUTO DODGE (Đã sửa lỗi khoảng cách)
-- ==========================================
_G.AutoDodge = false
DodgeBtn.MouseButton1Click:Connect(function()
    _G.AutoDodge = not _G.AutoDodge
    DodgeBtn.Text = "Auto Dodge: " .. (_G.AutoDodge and "BẬT" or "TẮT")
    DodgeBtn.BackgroundColor3 = _G.AutoDodge and Color3.fromRGB(46, 139, 87) or Color3.fromRGB(60, 60, 65)
end)

game.Workspace.ChildAdded:Connect(function(child)
    if _G.AutoDodge then
        pcall(function()
            if child.Name == "Hook" or child.Name == "Grapple" then
                local player = game.Players.LocalPlayer
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    task.wait(0.1) 
                    local hookPos = child:IsA("BasePart") and child.Position or (child:FindFirstChild("Handle") and child.Handle.Position)
                    
                    if hookPos then
                        local distance = (char.HumanoidRootPart.Position - hookPos).Magnitude
                        if distance < 40 then
                            char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(15, 0, 0)
                        end
                    end
                end
            end
        end)
    end
end)

-- ==========================================
-- LOGIC ESP (Đã sửa lỗi vòng lặp)
-- ==========================================
_G.ESPStatus = false
ESPBtn.MouseButton1Click:Connect(function()
    _G.ESPStatus = not _G.ESPStatus
    ESPBtn.Text = "ESP Player: " .. (_G.ESPStatus and "BẬT" or "TẮT")
    ESPBtn.BackgroundColor3 = _G.ESPStatus and Color3.fromRGB(46, 139, 87) or Color3.fromRGB(60, 60, 65)
    
    if not _G.ESPStatus then
        for _, player in pairs(game:GetService("Players"):GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("MinTESP") then
                player.Character.MinTESP:Destroy()
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if _G.ESPStatus then
            pcall(function()
                for _, player in pairs(game:GetService("Players"):GetPlayers()) do
                    if player ~= game:GetService("Players").LocalPlayer and player.Character then
                        if not player.Character:FindFirstChild("MinTESP") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "MinTESP"
                            highlight.Parent = player.Character
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            
                            if player.Team == game:GetService("Players").LocalPlayer.Team then
                                highlight.FillColor = Color3.fromRGB(0, 255, 0)
                            else
                                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                            end
                        end
                    end
                end
            end)
        end
    end
end)
