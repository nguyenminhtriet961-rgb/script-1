-- Hàm tạo nút chức năng
local function createToggle(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Parent = MainFrame
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
    btn.Position = UDim2.new(0.1, 0, 0, yPos)
    btn.Size = UDim2.new(0.8, 0, 0, 45)
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.TextSize = 16
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    return btn
end

local HitboxBtn = createToggle("Hitbox: TẮT", 60)
local DodgeBtn = createToggle("Auto Dodge: TẮT", 120)
local ESPBtn = createToggle("ESP Player: TẮT", 180)

-- Chức năng Đóng/Mở Menu
