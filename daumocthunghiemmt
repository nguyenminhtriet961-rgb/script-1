 
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
-- Chọn theme tối cho ngầu, chị có thể đổi thành "BloodTheme" hoặc "Ocean" nếu thích
local Window = Library.CreateLib("MinT Hook Bypass Hub 🎯", "SentinelTheme")

-- ==========================================
-- TẠO CÁC TAB & SECTION
-- ==========================================
local TabCombat = Window:NewTab("⚔️ Chiến Đấu")
local SecHitbox = TabCombat:NewSection("Thiết Lập Hitbox")
local SecDodge = TabCombat:NewSection("Hệ Thống Né Tránh")

local TabVisual = Window:NewTab("👁️ Hiển Thị")
local SecESP = TabVisual:NewSection("Hệ Thống Nhìn Xuyên Tường")

-- ==========================================
-- MODULE 1: HITBOX EXPANDER (Đã Fix lỗi CanCollide)
-- ==========================================
_G.HitboxStatus = false
_G.HitboxSize = 20

SecHitbox:NewToggle("Kích Hoạt Hitbox", "Làm to mục tiêu", function(state)
    _G.HitboxStatus = state
    if not state then
        -- FIXED: Khi tắt thì phải trả lại CanCollide về true để không làm hỏng game
        for _, v in pairs(game:GetService("Players"):GetPlayers()) do
            if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                v.Character.HumanoidRootPart.Transparency = 1
                v.Character.HumanoidRootPart.CanCollide = true 
            end
        end
    end
end)

SecHitbox:NewSlider("Kích Thước Hitbox", "Tùy chỉnh độ to", 50, 5, function(s)
    _G.HitboxSize = s
end)

task.spawn(function()
    while task.wait(1) do
        if _G.HitboxStatus then
            pcall(function()
                for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                    if v ~= game:GetService("Players").LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        v.Character.HumanoidRootPart.Transparency = 0.6
                        v.Character.HumanoidRootPart.CanCollide = false
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- MODULE 2: AUTO DODGE (Đã Fix lỗi né bóng ma)
-- ==========================================
_G.AutoDodge = false

SecDodge:NewToggle("Tự Động Né Móc", "Chỉ né khi Hook ở gần", function(state)
    _G.AutoDodge = state
end)

game.Workspace.ChildAdded:Connect(function(child)
    if _G.AutoDodge then
        pcall(function()
            if child.Name == "Hook" or child.Name == "Grapple" then
                local player = game.Players.LocalPlayer
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    -- Đợi 0.1s để vật thể load vị trí
                    task.wait(0.1) 
                    local hookPos = child:IsA("BasePart") and child.Position or (child:FindFirstChild("Handle") and child.Handle.Position)
                    
                    if hookPos then
                        -- FIXED: Tính toán khoảng cách, chỉ né khi nó cách mình dưới 40 studs
                        local distance = (char.HumanoidRootPart.Position - hookPos).Magnitude
                        if distance < 40 then
                            -- Nhảy ngang sang phải 15 studs
                            char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(15, 0, 0)
                        end
                    end
                end
            end
        end)
    end
end)

-- ==========================================
-- MODULE 3: ESP PLAYER (Đã Fix lỗi giật lag khi tắt)
-- ==========================================
_G.ESPStatus = false

SecESP:NewToggle("Bật ESP", "Phân biệt Địch (Đỏ) / Ta (Xanh)", function(state)
    _G.ESPStatus = state
    if not state then
        -- FIXED: Chỉ quét trong danh sách người chơi thay vì quét toàn bộ map
        for _, player in pairs(game:GetService("Players"):GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("MinTESP") then
                player.Character.MinTESP:Destroy()
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if _G.ESPStatus then
            pcall(function()
                for _, player in pairs(game:GetService("Players"):GetPlayers()) do
                    if player ~= game:GetService("Players").LocalPlayer and player.Character then
                        if not player.Character:FindFirstChild("MinTESP") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "MinTESP"
                            highlight.Parent = player.Character
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            
                            if player.Team == game:GetService("Players").LocalPlayer.Team then
                                highlight.FillColor = Color3.fromRGB(0, 255, 0)
                            else
                                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                            end
                        end
                    end
                end
            end)
        end
    end
end)
