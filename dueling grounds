-- ==========================================
-- TÊN SẢN PHẨM: SÁT THẦN LĨNH VỰC (BẢN TU TIÊN)
-- TÁC GIẢ: Em trai làm mướn
-- ==========================================

local player = game:GetService("Players").LocalPlayer
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local ChatService = game:GetService("Chat")
local Lighting = game:GetService("Lighting")
local Camera = game.Workspace.CurrentCamera

-- Tạo Tool
local tool = Instance.new("Tool", player.Backpack)
tool.Name = "🩸 Sát Thần Lĩnh Vực"
tool.RequiresHandle = false
local cooldown = false

-- Hàm tạo tia sét ngẫu nhiên
local function CreateLightning(domeCenter, radius)
    local p1 = domeCenter + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    local p2 = domeCenter + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    
    local distance = (p1 - p2).Magnitude
    local bolt = Instance.new("Part", workspace)
    bolt.Size = Vector3.new(0.5, 0.5, distance)
    bolt.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -distance/2)
    bolt.Anchored = true
    bolt.CanCollide = false
    bolt.Material = Enum.Material.Neon
    bolt.Color = Color3.fromRGB(255, 0, 50) -- Sét màu đỏ máu
    
    -- Xóa tia sét cực nhanh để tạo cảm giác chớp nháy
    Debris:AddItem(bolt, 0.1)
end

tool.Activated:Connect(function()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or cooldown then return end
    cooldown = true
    
    local root = char.HumanoidRootPart
    local head = char:FindFirstChild("Head")
    
    -- 1. Đẩy nhân vật bay lên trời 30 studs
    root.Velocity = Vector3.new(0, 0, 0)
    root.CFrame = root.CFrame * CFrame.new(0, 30, 0)
    root.Anchored = true -- Khóa trên không trung
    
    -- 2. Rung màn hình nhẹ & Hiệu ứng tối sầm vũ trụ
    local cc = Instance.new("ColorCorrectionEffect", Lighting)
    TweenService:Create(cc, TweenInfo.new(1), {Brightness = -0.5, Contrast = 1, TintColor = Color3.fromRGB(255, 100, 100)}):Play()
    
    task.wait(0.5)
    
    -- 3. Hét lên tên Lĩnh Vực (Bong bóng chat đỏ)
    if head then
        ChatService:Chat(head, "SÁT THẦN LĨNH VỰC!!!", Enum.ChatColor.Red)
    end
    
    task.wait(0.5)
    
    -- 4. Tạo Không Gian Lĩnh Vực (Dome)
    local dome = Instance.new("Part", workspace)
    dome.Shape = Enum.PartType.Ball
    dome.Size = Vector3.new(5, 5, 5)
    dome.CFrame = root.CFrame
    dome.Anchored = true
    dome.CanCollide = false
    dome.Material = Enum.Material.ForceField
    dome.Color = Color3.fromRGB(150, 0, 0)
    
    -- Cú nổ mở rộng Lĩnh Vực
    TweenService:Create(dome, TweenInfo.new(1, Enum.EasingStyle.Exponential), {Size = Vector3.new(150, 150, 150), Transparency = 0.5}):Play()
    TweenService:Create(Camera, TweenInfo.new(1), {FieldOfView = 90}):Play()
    
    -- 5. Tạo Mưa Máu (Blood Rain)
    local rainPart = Instance.new("Part", dome)
    rainPart.Size = Vector3.new(140, 1, 140)
    rainPart.CFrame = root.CFrame * CFrame.new(0, 70, 0) -- Nằm tít trên đỉnh Dome
    rainPart.Anchored = true
    rainPart.CanCollide = false
    rainPart.Transparency = 1
    
    local bloodRain = Instance.new("ParticleEmitter", rainPart)
    bloodRain.Texture = "rbxassetid://243660364" -- Vệt thẳng
    bloodRain.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0))
    bloodRain.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 2)})
    bloodRain.Lifetime = NumberRange.new(2)
    bloodRain.Rate = 1000 -- Đổ mưa xối xả
    bloodRain.Speed = NumberRange.new(100)
    bloodRain.EmissionDirection = Enum.NormalId.Bottom -- Trút xuống dưới
    
    -- 6. Vòng lặp duy trì Sét giật trong 10 giây
    local startTime = tick()
    task.spawn(function()
        while tick() - startTime < 10 do
            -- Cứ mỗi 0.1s đánh 1 tia sét ngẫu nhiên quanh Lĩnh Vực
            CreateLightning(root.Position, 60)
            -- Màn hình giật nhẹ liên tục
            Camera.CFrame = Camera.CFrame * CFrame.new(math.random(-1,1), math.random(-1,1), math.random(-1,1)) * 0.2
            task.wait(0.1)
        end
    end)
    
    -- Chờ đủ 10 giây
    task.wait(10)
    
    -- 7. Thu hồi Lĩnh Vực
    bloodRain.Enabled = false
    TweenService:Create(dome, TweenInfo.new(1), {Size = Vector3.new(0, 0, 0)}):Play()
    TweenService:Create(cc, TweenInfo.new(1), {Brightness = 0, Contrast = 0, TintColor = Color3.fromRGB(255, 255, 255)}):Play()
    TweenService:Create(Camera, TweenInfo.new(1), {FieldOfView = 70}):Play()
    
    task.wait(1)
    
    root.Anchored = false -- Thả chị rơi xuống đất lại
    dome:Destroy()
    cc:Destroy()
    
    task.wait(2) -- Cooldown để khỏi spam
    cooldown = false
end)
