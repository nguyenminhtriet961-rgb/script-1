--[[
    👑 MTRIET ULTIMATE - V18 KING SLAYER (AUTO HEAL EDITION) 👑
    - Gỡ bỏ giới hạn Job ID: Server nào cũng chạy được.
    - Tọa độ Không Gian mới: CFrame.new(391.8, 1285.3, 180.6)
    - Cơ chế Hồi Máu: 10 giây Đánh (Orbit) - 10 giây Nghỉ (Sky Freeze).
    - Max Hitbox cho Boss "King".
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- =======================================================
-- 🎯 CẤU HÌNH CỦA CHỊ MINT
-- =======================================================
local TOA_DO_KHONG_GIAN = CFrame.new(391.8, 1285.3, 180.6) -- Tọa độ chị vừa gửi
local BOSS_NAME = "King"
local ORBIT_SPEED = 6
local ORBIT_RADIUS = 12

local AutoComboBoss = false
local orbitAngle = 0

-- =======================================================
-- 🎨 GIAO DIỆN RAYFIELD
-- =======================================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "📱 KING SLAYER V18",
    LoadingTitle = "Đang nạp hệ thống diệt Boss...",
    LoadingSubtitle = "Chế độ Hồi Máu 10s/10s",
    ConfigurationSaving = { Enabled = false }, 
    KeySystem = false 
})

local TabBoss = Window:CreateTab("👹 Combo Diệt King")
local ComboToggle

ComboToggle = TabBoss:CreateToggle({
    Name = "🚀 Kích Hoạt Combo Đánh - Nghỉ (10s)", 
    CurrentValue = false, 
    Callback = function(v)
        AutoComboBoss = v
        if v then
            task.spawn(function()
                while AutoComboBoss do
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait(1) continue end

                    -- BƯỚC 1: BAY TỚI TỌA ĐỘ KHÔNG GIAN
                    print("▶️ Đang dịch chuyển tới khu vực Boss...")
                    hrp.Anchored = false
                    hrp.CFrame = TOA_DO_KHONG_GIAN
                    task.wait(2)

                    -- VÒNG LẶP CHIẾN ĐẤU CHÍNH
                    while AutoComboBoss do
                        local boss = workspace:FindFirstChild(BOSS_NAME, true)
                        
                        -- GIAI ĐOẠN 1: TẤN CÔNG (10 GIÂY)
                        if boss and boss:FindFirstChild("HumanoidRootPart") then
                            local bossHRP = boss.HumanoidRootPart
                            bossHRP.Size = Vector3.new(100, 100, 100) -- Tăng Hitbox tối đa
                            bossHRP.Transparency = 0.5
                            bossHRP.CanCollide = false
                            
                            print("⚔️ Giai đoạn: TẤN CÔNG (10s)")
                            local startTime = tick()
                            while AutoComboBoss and boss.Parent and (tick() - startTime < 10) do
                                RunService.Heartbeat:Wait()
                                orbitAngle = orbitAngle + math.rad(ORBIT_SPEED)
                                
                                -- Xoay quanh Boss
                                local offset = Vector3.new(math.cos(orbitAngle) * ORBIT_RADIUS, 5, math.sin(orbitAngle) * ORBIT_RADIUS)
                                hrp.CFrame = CFrame.new(bossHRP.Position + offset, bossHRP.Position)
                                
                                -- Tự cầm VP 2 và chém
                                local tool = LocalPlayer.Backpack:GetChildren()[2] or char:FindFirstChildOfClass("Tool")
                                if tool then
                                    char.Humanoid:EquipTool(tool)
                                    pcall(function() tool:Activate() end)
                                end
                            end
                        else
                            print("⏳ Đang đợi Boss xuất hiện...")
                            task.wait(1)
                        end

                        if not AutoComboBoss then break end

                        -- GIAI ĐOẠN 2: HỒI MÁU (10 GIÂY)
                        print("❤️ Giai đoạn: HỒI MÁU (10s) - Bay lên trời")
                        local healPos = hrp.Position + Vector3.new(0, 150, 0) -- Bay cao lên 150m
                        hrp.CFrame = CFrame.new(healPos)
                        task.wait(0.1)
                        hrp.Anchored = true -- Đóng băng trên trời để hồi máu an toàn
                        
                        task.wait(10) -- Đứng yên 10 giây
                        
                        hrp.Anchored = false -- Mở khóa để quay lại đánh tiếp
                    end
                end
            end)
        else
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.Anchored = false
            end
        end
    end
})

-- Tab Tiện ích giữ lại để chị lấy tọa độ nếu cần sửa
local TabOther = Window:CreateTab("⏳ Tiện Ích")
TabOther:CreateButton({
    Name = "📍 Lấy Tọa Độ (Copy)", 
    Callback = function() 
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local str = string.format("CFrame.new(%.1f, %.1f, %.1f)", char.HumanoidRootPart.Position.X, char.HumanoidRootPart.Position.Y, char.HumanoidRootPart.Position.Z)
            if setclipboard then setclipboard(str) end
            Rayfield:Notify({Title = "Đã Copy!", Content = str, Duration = 5})
        end
    end
})
