-- Biến lưu trữ trạng thái để dọn dẹp
local ActiveFeature = "None"
local FeatureConnections = {}

local function ClearAllFeatures()
    -- Ngắt tất cả các vòng lặp/sự kiện đang chạy
    for _, conn in ipairs(FeatureConnections) do
        if conn then conn:Disconnect() end
    end
    FeatureConnections = {}
    
    -- Dọn dẹp Hitbox lỡ như đang bật Hitbox Expander
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
            p.Character.HumanoidRootPart.Transparency = 1
            p.Character.HumanoidRootPart.CanCollide = true
        end
    end
end

-- Hàm tạo Nút bấm
local function CreateToggleButton(name, yPos, logicFunc)
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0.9, 0, 0, 30)
    Btn.Position = UDim2.new(0.05, 0, 0, yPos)
    Btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    Btn.Font = Enum.Font.GothamBold
    Btn.Text = name .. " [OFF]"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 14
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    
    return Btn
end

-- Khởi tạo 4 nút
local BtnParry = CreateToggleButton("Auto Parry", 40)
local BtnSilent = CreateToggleButton("Silent Aim", 75)
local BtnHitbox = CreateToggleButton("Hitbox Giấu", 110)
local BtnAntiStun = CreateToggleButton("Auto Lách", 145)

local AllButtons = {
    ["Auto Parry"] = BtnParry,
    ["Silent Aim"] = BtnSilent,
    ["Hitbox Giấu"] = BtnHitbox,
    ["Auto Lách"] = BtnAntiStun
}

-- ==========================================
-- LOGIC TÍNH NĂNG (HỆ THỐNG MÃ LÕI)
-- ==========================================

local Features = {
    ["Auto Parry"] = function()
        -- [LƯU Ý]: Auto Parry thật cần đọc ID Animation của game Dueling Grounds.
        -- Đây là khung logic mô phỏng: Cứ mỗi 0.1s kiểm tra nếu địch ở rất gần thì ấn Block.
        local conn = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local myPos = char.HumanoidRootPart.Position
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < 8 then -- Địch áp sát
                        -- Mô phỏng ấn phím F (Block)
                        keypress(0x46) 
                        task.wait(0.1)
                        keyrelease(0x46)
                    end
                end
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Silent Aim"] = function()
        -- Kéo góc nhìn nhẹ nhàng về phía thằng gần nhất mà không làm giật camera
        local conn = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            local cam = workspace.CurrentCamera
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            
            local closest = nil
            local shortest = 50 -- Bán kính 50 stud
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local dist = (p.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = p.Character.HumanoidRootPart
                    end
                end
            end
            
            if closest then
                -- Ép mặt chém về hướng mục tiêu (CFrame LookAt)
                char.HumanoidRootPart.CFrame = CFrame.new(char.HumanoidRootPart.Position, Vector3.new(closest.Position.X, char.HumanoidRootPart.Position.Y, closest.Position.Z))
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Hitbox Giấu"] = function()
        -- Phóng to hitbox địch nhưng để trong suốt, chị chém không khí vẫn trúng
        local conn = RunService.Heartbeat:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.Size = Vector3.new(15, 15, 15)
                    p.Character.HumanoidRootPart.Transparency = 1 -- Giấu đi cho tự nhiên
                    p.Character.HumanoidRootPart.CanCollide = false
                end
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Auto Lách"] = function()
        -- Tự động lùi (Lách) khi bị ăn sát thương (Mất máu)
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            local oldHealth = char.Humanoid.Health
            local conn = char.Humanoid.HealthChanged:Connect(function(newHealth)
                if newHealth < oldHealth then
                    -- Nếu mất máu -> tự động dịch chuyển giật lùi về sau 15 stud để né combo
                    if char:FindFirstChild("HumanoidRootPart") then
                        char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, 15)
                    end
                end
                oldHealth = newHealth
            end)
            table.insert(FeatureConnections, conn)
        end
    end
}

-- ==========================================
-- HỆ THỐNG NÚT ĐỘC QUYỀN (MUTEX LOGIC)
-- ==========================================

local function ActivateButton(btnName)
    -- Nếu đang bật rồi mà bấm lại -> TẮT TOÀN BỘ
    if ActiveFeature == btnName then
        ActiveFeature = "None"
        ClearAllFeatures()
        for name, btn in pairs(AllButtons) do
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            btn.Text = name .. " [OFF]"
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
        return
    end

    -- Bật chức năng mới: Dọn dẹp cái cũ trước
    ClearAllFeatures()
    ActiveFeature = btnName

    -- Chuyển toàn bộ nút về màu OFF (Xám/Đỏ)
    for name, btn in pairs(AllButtons) do
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        btn.Text = name .. " [OFF]"
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    end

    -- Bật Xanh (ON) cái nút đang bấm
    local activeBtn = AllButtons[btnName]
    activeBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50) -- Màu xanh lá
    activeBtn.Text = btnName .. " [ON]"
    activeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

    -- Gọi hàm tính năng tương ứng
    if Features[btnName] then
        Features[btnName]()
    end
end

-- Gắn sự kiện Click cho 4 nút
BtnParry.MouseButton1Click:Connect(function() ActivateButton("Auto Parry") end)
BtnSilent.MouseButton1Click:Connect(function() ActivateButton("Silent Aim") end)
BtnHitbox.MouseButton1Click:Connect(function() ActivateButton("Hitbox Giấu") end)
BtnAntiStun.MouseButton1Click:Connect(function() ActivateButton("Auto Lách") end)

-- Reset khi chết
LocalPlayer.CharacterAdded:Connect(function()
    if ActiveFeature ~= "None" then
        task.wait(1)
        local savedFeature = ActiveFeature
        ActiveFeature = "None"
        ActivateButton(savedFeature) -- Kích hoạt lại tính năng đang dùng
    end
end)
