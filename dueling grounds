--[[
    👑 MTRIET ULTIMATE - V14 BOSS SLAYER EDITION 👑
    - Tự động nhận diện Job ID server đặc biệt.
    - Combo Orbit: Xoay vòng quanh Boss + Max Hitbox + Spam VP 2.
    - Fix thăng bằng và trọng lực tuyệt đối.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- =======================================================
-- 🎯 THÔNG SỐ CẤU HÌNH CỦA CHỊ MINT:
-- =======================================================
local TARGET_JOB_ID = "fb541321-ec60-43ea-8834-4158fe763129" -- ID Server chị yêu cầu
local TOA_DO_BOSS_ZONE = CFrame.new(0, 100, 0) -- [!] CHỊ ĐIỀN TỌA ĐỘ CHỖ BOSS XUẤT HIỆN VÀO ĐÂY
local BOSS_NAME = "Vua Hắc Ám" -- Tên boss trong hình chị gửi
local ORBIT_SPEED = 5 -- Tốc độ quay quanh boss
local ORBIT_RADIUS = 10 -- Khoảng cách quay (bán kính)

-- =======================================================
-- 🎨 GIAO DIỆN RAYFIELD
-- =======================================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "📱 BOSS SLAYER V14",
    LoadingTitle = "Đang kiểm tra ID Server...",
    LoadingSubtitle = "Hệ thống chuyên trị Boss Hắc Ám",
    ConfigurationSaving = { Enabled = false }, 
    KeySystem = false 
})

local TabBoss = Window:CreateTab("👹 Diệt Boss")
local TabOther = Window:CreateTab("⏳ Tiện Ích")
local AutoSlay = false
local angle = 0

-- Hàm tìm Boss và tăng Hitbox
local function FixBoss(name)
    local target = workspace:FindFirstChild(name, true)
    if target and target:FindFirstChild("HumanoidRootPart") then
        local hrp = target.HumanoidRootPart
        hrp.Size = Vector3.new(50, 50, 50) -- Max Hitbox cho chị chém
        hrp.Transparency = 0.5
        hrp.CanCollide = false
        return hrp
    end
    return nil
end

TabBoss:CreateToggle({
    Name = "🚀 KÍCH HOẠT COMBO DIỆT BOSS", 
    CurrentValue = false, 
    Callback = function(v)
        AutoSlay = v
        if v then
            task.spawn(function()
                while AutoSlay do
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if not root then task.wait(1) continue end

                    -- BƯỚC 1: Bay tới tọa độ chờ Boss
                    root.Anchored = false
                    root.CFrame = TOA_DO_BOSS_ZONE
                    print("▶️ Đang chờ Boss xuất hiện...")
                    task.wait(5) -- Đợi 5 giây như chị yêu cầu

                    -- BƯỚC 2: Tìm Boss và bắt đầu Orbit (Quay quanh)
                    local bossHRP = FixBoss(BOSS_NAME)
                    if bossHRP then
                        -- Khóa thăng bằng
                        root.Velocity = Vector3.zero
                        
                        -- Vòng lặp quay và chém
                        while AutoSlay and bossHRP.Parent do
                            RunService.Heartbeat:Wait()
                            angle = angle + math.rad(ORBIT_SPEED)
                            
                            -- Tính toán vị trí quay quanh Boss
                            local offset = Vector3.new(math.cos(angle) * ORBIT_RADIUS, 5, math.sin(angle) * ORBIT_RADIUS)
                            root.CFrame = CFrame.new(bossHRP.Position + offset, bossHRP.Position)
                            
                            -- Spam Vật phẩm 2
                            local tool = LocalPlayer.Backpack:GetChildren()[2] or char:FindFirstChildOfClass("Tool")
                            if tool then
                                char.Humanoid:EquipTool(tool)
                                tool:Activate()
                            end
                        end
                    end
                    task.wait(1)
                end
            end)
        else
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.Anchored = false
            end
        end
    end
})

-- TỰ ĐỘNG CHẠY NẾU ĐÚNG ID SERVER
if game.JobId == TARGET_JOB_ID then
    Rayfield:Notify({Title = "ID Hợp Lệ!", Content = "Đang tự động dịch chuyển tới Boss Zone...", Duration = 5})
    task.wait(2)
    -- Chỗ này chị có thể gọi lệnh bật Toggle tự động nếu muốn
end

-- TIỆN ÍCH LẤY TỌA ĐỘ (Giữ lại cho chị điền vào dòng 12)
TabOther:CreateButton({
    Name = "📍 LẤY TỌA ĐỘ ĐỨNG (COPY)", 
    Callback = function() 
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local str = string.format("CFrame.new(%.1f, %.1f, %.1f)", char.HumanoidRootPart.Position.X, char.HumanoidRootPart.Position.Y, char.HumanoidRootPart.Position.Z)
            if setclipboard then setclipboard(str) end
            Rayfield:Notify({Title = "Đã Copy!", Content = str, Duration = 5})
        end
    end
})
