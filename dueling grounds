 
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local player = game:GetService("Players").LocalPlayer
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Camera = game.Workspace.CurrentCamera

local Window = Rayfield:CreateWindow({
    Name = "ANH TRIẾT Arsenal Hub 💣",
    LoadingTitle = "Đang rèn 14 loại vũ khí...",
    LoadingSubtitle = "Nhớ đừng spam gây lag máy",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

local TabArsenal = Window:CreateTab("🎒 Kho Đồ", nil)

-- Hàm kiểm tra tránh spam rác hòm đồ
local function CheckTool(toolName)
    local char = player.Character
    if player.Backpack:FindFirstChild(toolName) or (char and char:FindFirstChild(toolName)) then
        Rayfield:Notify({Title = "Lỗi!", Content = "Chị đã có món này rồi!", Duration = 2})
        return true
    end
    return false
end

-- ==========================================
-- HỆ THỐNG VŨ KHÍ CHÍNH (CÓ VFX RIÊNG)
-- ==========================================
TabArsenal:CreateSection("🔥 Vũ Khí Đặc Quyền")

-- 1. TIA CHỚP (ĐÃ THÊM PROCEDURAL ANIMATION)
TabArsenal:CreateButton({
    Name = "⚡ Tia Chớp MinT (Lướt + Camera Anim)",
    Callback = function()
        if CheckTool("⚡ Tia Chớp MinT") then return end
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "⚡ Tia Chớp MinT", false
        local cooldown = false

        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            if cooldown then return end
            cooldown = true
            
            local root = char.HumanoidRootPart
            
            -- [ANIMATION CAMERA MƯỢT]
            local blur = Instance.new("BlurEffect", Camera)
            blur.Size = 24
            TweenService:Create(Camera, TweenInfo.new(0.2, Enum.EasingStyle.Cubic), {FieldOfView = 100}):Play()
            
            local raycastResult = game.Workspace:Raycast(root.Position, root.CFrame.LookVector * 50, RaycastParams.new())
            root.CFrame = raycastResult and CFrame.new(raycastResult.Position) or (root.CFrame * CFrame.new(0, 0, -50))
            
            -- Trả camera về bình thường
            task.wait(0.2)
            TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Cubic), {FieldOfView = 70}):Play()
            TweenService:Create(blur, TweenInfo.new(0.3), {Size = 0}):Play()
            Debris:AddItem(blur, 0.4)
            
            task.wait(1)
            cooldown = false
        end)
    end,
})

-- ==========================================
-- HỆ THỐNG 10 VẬT PHẨM MỚI (TỐI ƯU BẰNG TABLE LẶP)
-- ==========================================
TabArsenal:CreateSection("🛠️ 10 Vật Phẩm Phụ Trợ (Mới)")

-- Danh sách 10 kỹ năng được viết dưới dạng mảng để tiết kiệm RAM
local extraTools = {
    {"👻 Áo Choàng Tàng Hình", function(root, char)
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") then v.Transparency = 1 end
        end
        task.wait(5)
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then v.Transparency = 0 end
            if v:IsA("Decal") then v.Transparency = 0 end
        end
    end},
    {"👟 Giày Cuồng Phong (Tốc chạy)", function(root, char, hum)
        hum.WalkSpeed = 100
        task.wait(3)
        hum.WalkSpeed = 16
    end},
    {"🛡️ Lá Chắn Bất Tử", function(root, char)
        local ff = Instance.new("ForceField", char)
        Debris:AddItem(ff, 5)
    end},
    {"❄️ Đóng Băng Bản Thân (Né đòn)", function(root, char)
        root.Anchored = true
        local ice = Instance.new("Part", root)
        ice.Size = Vector3.new(5, 6, 5)
        ice.Material, ice.Color = Enum.Material.Ice, Color3.fromRGB(150, 200, 255)
        ice.Transparency, ice.Anchored, ice.CFrame = 0.5, true, root.CFrame
        Debris:AddItem(ice, 3)
        task.wait(3)
        root.Anchored = false
    end},
    {"🔥 Hỏa Nộ (Vòng Lửa)", function(root, char)
        local fire = Instance.new("Fire", root)
        fire.Size = 15
        Debris:AddItem(fire, 5)
    end},
    {"🎈 Thuốc Khinh Công (Bay lơ lửng)", function(root, char)
        local bv = Instance.new("BodyVelocity", root)
        bv.Velocity = Vector3.new(0, 20, 0)
        bv.MaxForce = Vector3.new(0, 100000, 0)
        Debris:AddItem(bv, 3)
    end},
    {"💚 Hồi Máu Ảo (Troll)", function(root, char, hum)
        local spark = Instance.new("Sparkles", root)
        spark.SparkleColor = Color3.fromRGB(0, 255, 0)
        Debris:AddItem(spark, 2)
        -- Chỉ là hiệu ứng xanh lá, không hồi máu thật vì vướng server
    end},
    {"🎲 Dịch Chuyển Hỗn Loạn", function(root, char)
        local rx, rz = math.random(-50, 50), math.random(-50, 50)
        root.CFrame = root.CFrame * CFrame.new(rx, 50, rz)
    end},
    {"🌀 Bão Trọng Lực (Đẩy lùi)", function(root, char)
        local blast = Instance.new("Part", workspace)
        blast.Size, blast.Shape = Vector3.new(1,1,1), Enum.PartType.Ball
        blast.Material, blast.Color = Enum.Material.ForceField, Color3.fromRGB(255, 50, 255)
        blast.CFrame, blast.Anchored, blast.CanCollide = root.CFrame, true, false
        TweenService:Create(blast, TweenInfo.new(0.5), {Size = Vector3.new(30, 30, 30), Transparency = 1}):Play()
        Debris:AddItem(blast, 0.5)
    end},
    {"📉 Đột Tử (Tự hủy nghệ thuật)", function(root, char, hum)
        local exp = Instance.new("Explosion", workspace)
        exp.Position = root.Position
        hum.Health = 0
    end}
}

-- Trình tạo tự động 10 nút vật phẩm
for i, item in ipairs(extraTools) do
    TabArsenal:CreateButton({
        Name = item[1],
        Callback = function()
            if CheckTool(item[1]) then return end
            local tool = Instance.new("Tool", player.Backpack)
            tool.Name, tool.RequiresHandle = item[1], false
            local cd = false
            
            tool.Activated:Connect(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") and not cd then
                    cd = true
                    -- Gọi hàm kỹ năng
                    item[2](char.HumanoidRootPart, char, char:FindFirstChild("Humanoid"))
                    task.wait(2) -- Cooldown cơ bản
                    cd = false
                end
            end)
        end,
    })
end
-- ==========================================
-- CHỨC NĂNG: DỌN KHO (XÓA VẬT PHẨM DO SCRIPT TẠO)
-- ==========================================
TabArsenal:CreateSection("🧹 Quản Lý Túi Đồ")

TabArsenal:CreateButton({
    Name = "Xóa Tất Cả Vật Phẩm MinT",
    Callback = function()
        local backpack = player.Backpack
        local char = player.Character
        local count = 0

        -- Hàm quét và xóa
        local function clear(container)
            for _, item in pairs(container:GetChildren()) do
                if item:IsA("Tool") then
                    -- Chỉ xóa những món có icon hoặc tên đặc biệt mình đã đặt
                    if item.Name:find("⚡") or item.Name:find("🌪️") or item.Name:find("👥") or 
                       item.Name:find("🌑") or item.Name:find("👻") or item.Name:find("👟") or 
                       item.Name:find("🛡️") or item.Name:find("❄️") or item.Name:find("🔥") or 
                       item.Name:find("🎈") or item.Name:find("💚") or item.Name:find("🎲") or 
                       item.Name:find("🌀") or item.Name:find("📉") then
                        item:Destroy()
                        count = count + 1
                    end
                end
            end
        end

        clear(backpack)
        if char then clear(char) end

        Rayfield:Notify({
            Title = "Đã Dọn Dẹp!",
            Content = "Đã tống khứ " .. count .. " món đồ chơi rác rưởi.",
            Duration = 3,
            Image = 4483362458,
        })
    end,
})
