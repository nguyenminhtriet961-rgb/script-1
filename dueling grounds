TabGhost:CreateSection("Pháp Bảo: Ảo Ảnh Hắc Ám")

TabGhost:CreateButton({
    Name = "Nhận: 👻 Ghost Mode [Tiến Hóa]",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name = "👻 Ghost Mode [LV"..currentLevel.."]"
        tool.RequiresHandle = false
        
        local isGhost = false
        local ghostEffectConn
        
        tool.Activated:Connect(function()
            isGhost = not isGhost
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if not hum or not root then return end
            
            if isGhost then
                -- BẮT ĐẦU TRẠNG THÁI GHOST
                PlaySound(231917744, 0.8) -- Âm thanh kích hoạt
                
                -- Làm mờ nhân vật
                for _, p in ipairs(char:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then 
                        p.Transparency = 0.5 
                    end 
                end
                
                ghostEffectConn = RunService.RenderStepped:Connect(function()
                    if not char or not hum then return end
                    
                    if currentLevel == 1 then
                        -- CẤP 1: Đứng yên không thể di chuyển
                        hum.WalkSpeed = 0
                        hum.JumpPower = 0
                    elseif currentLevel == 2 then
                        -- CẤP 2: Di chuyển bình thường
                        hum.WalkSpeed = 16
                        hum.JumpPower = 50
                    elseif currentLevel == 3 then
                        -- CẤP 3: Chạy nhanh + Tạo bóng ma (Trail)
                        hum.WalkSpeed = 45
                        hum.JumpPower = 50
                        if hum.MoveDirection.Magnitude > 0 then CreateGhostTrail(char) end
                    elseif currentLevel == 4 then
                        -- CẤP 4: Siêu tốc độ + Sấm sét tận thế
                        hum.WalkSpeed = 100
                        hum.JumpPower = 100
                        if hum.MoveDirection.Magnitude > 0 then CreateGhostTrail(char) end
                        
                        -- Hiệu ứng sét đánh xung quanh khi di chuyển
                        if math.random(1, 15) == 1 then
                            local l = Instance.new("Part", workspace)
                            l.Size = Vector3.new(1, math.random(20, 100), 1)
                            l.Anchored = true; l.CanCollide = false; l.Material = Enum.Material.Neon
                            l.Color = Color3.fromRGB(255, 255, 255)
                            l.CFrame = root.CFrame * CFrame.new(math.random(-20,20), 20, math.random(-20,20))
                            Debris:AddItem(l, 0.1)
                            PlaySound(142070127, 1.2, 0.3)
                        end
                    end
                end)
                
                Rayfield:Notify({Title = "Ghost Mode", Content = "Đã vào trạng thái linh hồn (Cấp "..currentLevel..")", Duration = 2})
            else
                -- TẮT TRẠNG THÁI GHOST
                if ghostEffectConn then ghostEffectConn:Disconnect() end
                for _, p in ipairs(char:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then 
                        p.Transparency = 0 
                    end 
                end
                hum.WalkSpeed = 16
                hum.JumpPower = 50
                Rayfield:Notify({Title = "Ghost Mode", Content = "Đã trở lại thực tại", Duration = 2})
            end
        end)
        
        -- Khi vứt tool hoặc đổi sang item khác thì tự tắt hiệu ứng để tránh lỗi WalkSpeed
        tool.Unequipped:Connect(function()
            isGhost = false
            if ghostEffectConn then ghostEffectConn:Disconnect() end
            local char = player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = 16
                char.Humanoid.JumpPower = 50
                for _, p in ipairs(char:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 0 end 
                end
            end
        end)
    end
})
