        task.wait(2); hum.WalkSpeed = 16; bv:Destroy(); Debris:AddItem(wind, 0)
    end},

    {"👻 Quỷ Ảnh Xuyên Tường", function(root, char)
        local result = workspace:Raycast(root.Position, root.CFrame.LookVector * 4, RaycastParams.new())
        if not result then return end 
        PlaySound(231917744, 0.5, root)
        local oldMat = {}
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("BasePart") then oldMat[v] = v.Material; v.Material = Enum.Material.ForceField; v.CanCollide = false end
        end
        local tw = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {CFrame = root.CFrame * CFrame.new(0, 0, -8)})
        tw:Play(); tw.Completed:Wait()
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("BasePart") then v.Material = oldMat[v] or Enum.Material.Plastic; v.CanCollide = true end
        end
    end},

    {"✝️ Thánh Quang Hộ Thể", function(root, char, hum)
        PlaySound(142070127, 1.5, root); root.Anchored = true
        local aura = Instance.new("Part", workspace)
        aura.Shape, aura.Size, aura.Anchored, aura.CanCollide, aura.Material, aura.Color = Enum.PartType.Cylinder, Vector3.new(100, 15, 15), true, false, Enum.Material.Neon, Color3.fromRGB(255, 215, 0)
        aura.CFrame = root.CFrame * CFrame.Angles(0, 0, math.rad(90)) * CFrame.new(0, 0, 0)
        TweenService:Create(root, TweenInfo.new(1), {CFrame = root.CFrame * CFrame.new(0, 50, 0)}):Play()
        task.wait(5); root.Anchored = false
        TweenService:Create(aura, TweenInfo.new(0.5), {Transparency = 1, Size = Vector3.new(100,0,0)}):Play()
        Debris:AddItem(aura, 0.5)
    end},

    {"🗡️ Sát Thủ Phục Kích", function(root, char)
        local target = nil; local minDist = 150
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                if dist < minDist then minDist = dist; target = p.Character.HumanoidRootPart end
            end
        end
        if target then
            PlaySound(2248511, 2, root)
            local smoke = Instance.new("Part", workspace)
            smoke.Size, smoke.CFrame, smoke.Anchored, smoke.Material, smoke.Color = Vector3.new(5,5,5), root.CFrame, true, Enum.Material.Neon, Color3.new(0,0,0)
            TweenService:Create(smoke, TweenInfo.new(0.5), {Size = Vector3.new(0,0,0)}):Play(); Debris:AddItem(smoke, 0.5)
            root.CFrame = target.CFrame * CFrame.new(0, 0, 4)
            PlaySound(231917744, 1.5, root)
        end
    end},

    {"🌫️ Ảo Ảnh Hắc Ám (VIP)", function(root, char, hum)
        PlaySound(178452221, 0.5, root)
        local cc = Instance.new("ColorCorrectionEffect", Lighting)
        cc.Saturation = -1; cc.Contrast = 0.2; cc.TintColor = Color3.fromRGB(150, 150, 150)
        
        local smokeParticle = Instance.new("ParticleEmitter", root)
        smokeParticle.Texture = "rbxassetid://243660364" 
        smokeParticle.Color = ColorSequence.new(Color3.fromRGB(30, 30, 30))
        smokeParticle.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 4)})
        smokeParticle.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
        smokeParticle.Lifetime = NumberRange.new(0.5, 1); smokeParticle.Rate = 50; smokeParticle.Speed = NumberRange.new(2, 5)
        
        local oldTrans = {}; local oldMat = {}
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                oldTrans[v] = v.Transparency; oldMat[v] = v.Material
                v.Transparency = 0.6; v.Material = Enum.Material.ForceField 
            elseif v:IsA("Decal") then
                oldTrans[v] = v.Transparency; v.Transparency = 0.6
            end
        end
        
        local timer = 0
        local connection = RunService.RenderStepped:Connect(function(dt)
            timer = timer + dt
            if timer > 0.1 and hum.MoveDirection.Magnitude > 0 then 
                CreateGhostTrail(char); timer = 0 
            end
        end)
        
        task.wait(5)
        
        connection:Disconnect(); cc:Destroy(); smokeParticle.Enabled = false; Debris:AddItem(smokeParticle, 1)
        for v, trans in pairs(oldTrans) do
            if v and v.Parent then 
                v.Transparency = trans 
                if v:IsA("BasePart") and oldMat[v] then v.Material = oldMat[v] end
            end
        end
    end}
}

