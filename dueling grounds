local NoclipConnection = nil

TabGhost:CreateSection("Pháp Bảo: Ảo Ảnh Hắc Ám (Tàng Hình Thực Sự)")

TabGhost:CreateButton({
    Name = "Nhận: 👻 Ghost Mode [Real]",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name = "👻 Ghost Mode [Tàng Hình]"
        tool.RequiresHandle = false
        
        local isRealGhost = false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local hum = char:FindFirstChild("Humanoid")
            
            isRealGhost = not isRealGhost
            
            if isRealGhost then
                -- BẬT GHOST MODE (Tàng hình + Xuyên tường + Tốc độ)
                PlaySound(231917744, 0.8)
                
                -- Làm mờ model ở máy mình cho có cảm giác
                for _, p in ipairs(char:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 0.5 end 
                end
                
                -- Seat Glitch (Giấu model để người khác không thấy)
                local savedpos = char.HumanoidRootPart.CFrame
                task.wait()
                char:MoveTo(Vector3.new(-25.95, 84, 3537.55)) -- Ném xác ra góc khuất map
                task.wait(0.15)
                local Seat = Instance.new("Seat")
                Seat.Anchored, Seat.CanCollide, Seat.Name, Seat.Transparency = false, false, "invischair", 1
                Seat.Position = Vector3.new(-25.95, 84, 3537.55)
                Seat.Parent = workspace
                local Weld = Instance.new("Weld", Seat)
                Weld.Part0, Weld.Part1 = Seat, char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                Seat.CFrame = savedpos -- Đưa hitbox về lại chỗ cũ
                
                -- Tăng tốc độ dựa vào Cấp Độ (Lv1=60, Lv2=80...)
                if hum then
                    hum.WalkSpeed = 40 + (currentLevel * 20) 
                end
                
                -- Bật Noclip (Xuyên tường)
                if NoclipConnection then NoclipConnection:Disconnect() end
                NoclipConnection = RunService.Stepped:Connect(function()
                    if player.Character then
                        for _, part in ipairs(player.Character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = false end
                        end
                    end
                end)
                
                Rayfield:Notify({Title = "Ghost Mode", Content = "Đã bật: Tàng hình 100% + Xuyên tường + Chạy nhanh", Duration = 2})
            else
                -- TẮT GHOST MODE
                -- Tắt xuyên tường
                if NoclipConnection then 
                    NoclipConnection:Disconnect() 
                    NoclipConnection = nil 
                end
                
                -- Tắt tàng hình & phục hồi
                for _, p in ipairs(char:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 0 end 
                end
                if workspace:FindFirstChild("invischair") then workspace.invischair:Destroy() end
                if hum then 
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp) 
                    hum.WalkSpeed = 16
                end
                
                Rayfield:Notify({Title = "Ghost Mode", Content = "Đã hiện hình lại", Duration = 2})
            end
        end)
        
        -- Nếu đang tàng hình mà cất vật phẩm (Unequipped) thì tự động hiện hình để tránh kẹt lỗi
        tool.Unequipped:Connect(function()
            if isRealGhost then
                local char = player.Character
                if NoclipConnection then NoclipConnection:Disconnect(); NoclipConnection = nil end
                if char then
                    for _, p in ipairs(char:GetDescendants()) do 
                        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 0 end 
                    end
                    if workspace:FindFirstChild("invischair") then workspace.invischair:Destroy() end
                    local hum = char:FindFirstChild("Humanoid")
                    if hum then 
                        hum:ChangeState(Enum.HumanoidStateType.GettingUp) 
                        hum.WalkSpeed = 16
                    end
                end
                isRealGhost = false
                Rayfield:Notify({Title = "Ghost Mode", Content = "Bị cất vật phẩm, tự động hiện hình!", Duration = 2})
            end
        end)
    end
})
