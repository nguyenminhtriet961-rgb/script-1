    local onof = Instance.new("TextButton", Frame); onof.Size = UDim2.new(1, 0, 1, 0); onof.Text = "BẬT FLY"; onof.TextColor3 = Color3.new(1,1,1); onof.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    
    local nowe = false
    local speeds = 50
    onof.MouseButton1Down:connect(function()
        nowe = not nowe
        if nowe then onof.Text = "TẮT FLY"; onof.BackgroundColor3 = Color3.fromRGB(200, 50, 50) else onof.Text = "BẬT FLY"; onof.BackgroundColor3 = Color3.fromRGB(0, 120, 215) end
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        
        if nowe then
            hum:ChangeState(Enum.HumanoidStateType.Swimming)
            local bg = Instance.new("BodyGyro", char.HumanoidRootPart); bg.P = 9e4; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bg.cframe = char.HumanoidRootPart.CFrame
            local bv = Instance.new("BodyVelocity", char.HumanoidRootPart); bv.velocity = Vector3.new(0,0.1,0); bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
            task.spawn(function()
                while nowe do
                    RunService.RenderStepped:Wait()
                    if hum.MoveDirection.Magnitude > 0 then
                        bv.velocity = Camera.CFrame.lookVector * speeds * (hum.MoveDirection.Z < 0 and 1 or -1)
                        if hum.MoveDirection.X ~= 0 then bv.velocity = bv.velocity + (Camera.CFrame.RightVector * speeds * hum.MoveDirection.X) end
                    else
                        bv.velocity = Vector3.new(0,0.1,0)
                    end
                    bg.cframe = Camera.CFrame
                end
                bg:Destroy(); bv:Destroy()
            end)
        else
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)
end})
