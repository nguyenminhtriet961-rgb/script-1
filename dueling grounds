--[[
    👑 MTRIET EXPERIMENTAL - NO COOLDOWN BYPASS 👑
    - Chức năng: Lục soát bộ nhớ (getgc) để ép thời gian hồi chiêu về 0.
    - Cảnh báo: Chỉ hoạt động với các game code cooldown ở Client.
]]

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "📱 MTRIET BYPASS",
    LoadingTitle = "Đang nạp hệ thống...",
    LoadingSubtitle = "Thử nghiệm No Cooldown",
    ConfigurationSaving = { Enabled = false }, 
    KeySystem = false 
})

local TabHack = Window:CreateTab("⚡ Hack Cooldown")

TabHack:CreateButton({
    Name = "🔨 Ép Hồi Chiêu Về 0 (Quét Bộ Nhớ)", 
    Callback = function()
        local count = 0
        -- Quét toàn bộ Garbage Collector (Bộ nhớ tạm của game)
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" then
                -- Tìm các biến thường được Dev dùng để làm hồi chiêu
                if rawget(v, "Cooldown") then 
                    v.Cooldown = 0 
                    count = count + 1
                end
                if rawget(v, "Debounce") then 
                    v.Debounce = 0 
                    count = count + 1
                end
                if rawget(v, "WaitTime") then 
                    v.WaitTime = 0 
                    count = count + 1
                end
                if rawget(v, "Tick") then 
                    v.Tick = 0 
                    count = count + 1
                end
            end
        end
        
        if count > 0 then
            Rayfield:Notify({Title = "Thành công", Content = "Đã bẻ khóa " .. count .. " biến hồi chiêu!", Duration = 5})
        else
            Rayfield:Notify({Title = "Thất bại", Content = "Không tìm thấy biến hồi chiêu ở Client.", Duration = 5})
        end
    end
})
