-- HÀM HỖ TRỢ SFX & VFX
-- ==========================================
local function PlaySound(id, pitch, parent)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = 2; s.Pitch = pitch or 1; s.Parent = parent or workspace
    s:Play(); Debris:AddItem(s, 3)
end

local function CreateGhostTrail(char)
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = part:Clone()
            clone.Parent = workspace
            clone.Anchored = true
            clone.CanCollide = false
            clone.Material = Enum.Material.ForceField
            clone.Color = Color3.new(1, 1, 1) -- Bóng trắng ngầu
            TweenService:Create(clone, TweenInfo.new(0.5), {Transparency = 1}):Play()
            Debris:AddItem(clone, 0.5)
        end
    end
end

