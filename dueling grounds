local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- Tạo GUI cơ bản
local SG = Instance.new("ScreenGui")
SG.Name = "MTRIET_DuelingHub"
SG.ResetOnSpawn = false
pcall(function() SG.Parent = CoreGui end)
if not SG.Parent then SG.Parent = LocalPlayer:WaitForChild("PlayerGui") end

local Frame = Instance.new("Frame", SG)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Frame.Position = UDim2.new(0.5, -100, 0.1, 0)
Frame.Size = UDim2.new(0, 200, 0, 190)
Frame.Active = true
Frame.Draggable = true
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", Frame).Color = Color3.fromRGB(255, 170, 0) -- Viền cam VIP
Instance.new("UIStroke", Frame).Thickness = 2

local Title = Instance.new("TextLabel", Frame)
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundTransparency = 1
Title.Font = Enum.Font.GothamBold
Title.Text = "👑 MINH TRIẾT VIP"
Title.TextColor3 = Color3.fromRGB(255, 200, 0)
Title.TextSize = 15

local CloseBtn = Instance.new("TextButton", Frame)
CloseBtn.Size = UDim2.new(0, 30, 0, 30)
CloseBtn.Position = UDim2.new(1, -30, 0, 0)
CloseBtn.BackgroundTransparency = 1
CloseBtn.Font = Enum.Font.GothamBold
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
CloseBtn.TextSize = 16
CloseBtn.MouseButton1Click:Connect(function() SG:Destroy() end)

-- Biến lưu trạng thái
local ActiveFeature = "None"
local FeatureConnections = {}

local function ClearAllFeatures()
    for _, conn in ipairs(FeatureConnections) do
        if conn then conn:Disconnect() end
    end
    FeatureConnections = {}
    
    -- Dọn dẹp Hitbox
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
            p.Character.HumanoidRootPart.Transparency = 1
            p.Character.HumanoidRootPart.CanCollide = true
        end
    end
end

-- Hàm tạo Nút bấm
local function CreateToggleButton(name, yPos)
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0.9, 0, 0, 30)
    Btn.Position = UDim2.new(0.05, 0, 0, yPos)
    Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Btn.Font = Enum.Font.GothamBold
    Btn.Text = name .. " [TẮT]"
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.TextSize = 14
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    return Btn
end

-- Khởi tạo 4 nút Tiếng Việt
local BtnParry = CreateToggleButton("Tự Động Đỡ", 40)
local BtnSilent = CreateToggleButton("Chém Trúng Đích", 75)
local BtnHitbox = CreateToggleButton("Vùng Đánh Giấu", 110)
local BtnAntiStun = CreateToggleButton("Tự Động Lách", 145)

local AllButtons = {
    ["Tự Động Đỡ"] = BtnParry,
    ["Chém Trúng Đích"] = BtnSilent,
    ["Vùng Đánh Giấu"] = BtnHitbox,
    ["Tự Động Lách"] = BtnAntiStun
}

-- ==========================================
-- LOGIC TÍNH NĂNG (ĐÃ TỐI ƯU HÓA)
-- ==========================================

local Features = {
    ["Tự Động Đỡ"] = function()
        -- Dùng VirtualInputManager để không bị kẹt khi đang di chuyển
        local conn = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local myPos = char.HumanoidRootPart.Position
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    -- Kiểm tra địch có đang cầm vũ khí không
                    local enemyHasWeapon = p.Character:FindFirstChildOfClass("Tool")
                    local dist = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
                    
                    -- Nếu địch cầm vũ khí và áp sát (10 stud)
                    if dist < 10 and enemyHasWeapon then
                        -- Giả lập bấm phím F mượt mà
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                        task.wait(0.05)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                        task.wait(0.3) -- Nghỉ 0.3s để không bị liệt phím
                    end
                end
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Chém Trúng Đích"] = function()
        local conn = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            
            local closest = nil
            local shortest = 30 -- Khoảng cách khóa mục tiêu
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local dist = (p.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = p.Character.HumanoidRootPart
                    end
                end
            end
            
            if closest then
                char.HumanoidRootPart.CFrame = CFrame.new(char.HumanoidRootPart.Position, Vector3.new(closest.Position.X, char.HumanoidRootPart.Position.Y, closest.Position.Z))
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Vùng Đánh Giấu"] = function()
        local conn = RunService.Heartbeat:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.Size = Vector3.new(12, 12, 12)
                    p.Character.HumanoidRootPart.Transparency = 1 
                    p.Character.HumanoidRootPart.CanCollide = false
                end
            end
        end)
        table.insert(FeatureConnections, conn)
    end,

    ["Tự Động Lách"] = function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            local oldHealth = char.Humanoid.Health
            local conn = char.Humanoid.HealthChanged:Connect(function(newHealth)
                if newHealth < oldHealth then
                    if char:FindFirstChild("HumanoidRootPart") then
                        -- Tự giật lùi về sau 15 stud khi mất máu
                        char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, 15)
                    end
                end
                oldHealth = newHealth
            end)
            table.insert(FeatureConnections, conn)
        end
    end
}

-- ==========================================
-- HỆ THỐNG NÚT BẤM ĐỘC QUYỀN
-- ==========================================

local function ActivateButton(btnName)
    if ActiveFeature == btnName then
        ActiveFeature = "None"
        ClearAllFeatures()
        for name, btn in pairs(AllButtons) do
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            btn.Text = name .. " [TẮT]"
            btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        return
    end

    ClearAllFeatures()
    ActiveFeature = btnName

    for name, btn in pairs(AllButtons) do
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        btn.Text = name .. " [TẮT]"
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    end

    local activeBtn = AllButtons[btnName]
    activeBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50) 
    activeBtn.Text = btnName .. " [BẬT]"
    activeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

    if Features[btnName] then
        Features[btnName]()
    end
end

BtnParry.MouseButton1Click:Connect(function() ActivateButton("Tự Động Đỡ") end)
BtnSilent.MouseButton1Click:Connect(function() ActivateButton("Chém Trúng Đích") end)
BtnHitbox.MouseButton1Click:Connect(function() ActivateButton("Vùng Đánh Giấu") end)
BtnAntiStun.MouseButton1Click:Connect(function() ActivateButton("Tự Động Lách") end)

LocalPlayer.CharacterAdded:Connect(function()
    if ActiveFeature ~= "None" then
        task.wait(1)
        local savedFeature = ActiveFeature
        ActiveFeature = "None"
        ActivateButton(savedFeature)
    end
end)
