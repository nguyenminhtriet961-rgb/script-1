            TweenService:Create(cc, TweenInfo.new(1), {Brightness = 0, Contrast = 0, TintColor = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(Camera, TweenInfo.new(1), {FieldOfView = 70}):Play()
            
            task.wait(1)
            root.Anchored = false 
            dome:Destroy(); cc:Destroy()
            task.wait(2); cooldown = false
        end)
    end
})

