                    local p1 = root.Position + Vector3.new(math.random(-60, 60), math.random(-60, 60), math.random(-60, 60))
                    local p2 = root.Position + Vector3.new(math.random(-60, 60), math.random(-60, 60), math.random(-60, 60))
