    end},

    {"🎈 Đạp Không Hành", function(root, char, hum)
        PlaySound(178452221, 2, root)
        hum.WalkSpeed = 50
        local bv = Instance.new("BodyVelocity", root); bv.MaxForce = Vector3.new(0, 100000, 0); bv.Velocity = Vector3.new(0, 5, 0)
        local wind = Instance.new("Part", char)
        wind.Size, wind.Anchored, wind.CanCollide, wind.Material, wind.Color = Vector3.new(4,0.1,4), true, false, Enum.Material.ForceField, Color3.fromRGB(150, 255, 255)
