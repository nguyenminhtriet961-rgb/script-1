-- 6 VẬT PHẨM ĐỈNH CAO
-- ==========================================
local Arsenal = {
    -- 1. LƯỚT CHỐNG ĐỤNG TƯỜNG
    {"⚡ Lướt Phong Thần", function(root, char)
        PlaySound(2248511, 1.2, root) -- Tiếng xé gió
        
        -- Dùng Raycast để đo khoảng cách tới tường
        local rayOrigin = root.Position
        local rayDirection = root.CFrame.LookVector * 50
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {char}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        
        local targetCFrame
        local result = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
        
        if result then
            -- Nếu gặp tường, lướt tới cách tường 2 studs để không bị cộc đầu
            targetCFrame = CFrame.new(result.Position - (root.CFrame.LookVector * 2))
        else
            -- Không có tường thì lướt max 50 studs
            targetCFrame = root.CFrame * CFrame.new(0, 0, -50)
        end
        
        TweenService:Create(Camera, TweenInfo.new(0.1), {FieldOfView = 100}):Play()
        local tw = TweenService:Create(root, TweenInfo.new(0.2, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
        tw:Play()
        tw.Completed:Wait()
        TweenService:Create(Camera, TweenInfo.new(0.3), {FieldOfView = 70}):Play()
    end},

    -- 2. LƠ LỬNG TRÊN KHÔNG
    {"🎈 Đạp Không Hành", function(root, char, hum)
        PlaySound(178452221, 2, root)
        hum.WalkSpeed = 50 -- Chạy nhanh
        
        -- Animation lơ lửng giả lập (Nhấc nhẹ người lên)
        local bv = Instance.new("BodyVelocity", root)
        bv.MaxForce = Vector3.new(0, 100000, 0)
        bv.Velocity = Vector3.new(0, 5, 0) -- Nổi từ từ lên
        
        -- Hiệu ứng gió dưới chân
        local wind = Instance.new("Part", char)
        wind.Size, wind.Anchored, wind.CanCollide, wind.Material = Vector3.new(4,0.1,4), true, false, Enum.Material.ForceField
        wind.Color = Color3.fromRGB(150, 255, 255)
        wind.CFrame = root.CFrame * CFrame.new(0,-3,0)
        TweenService:Create(wind, TweenInfo.new(2), {CFrame = wind.CFrame * CFrame.Angles(0,math.rad(360),0)}):Play()
        
        task.wait(2)
        hum.WalkSpeed = 16
        bv:Destroy()
        Debris:AddItem(wind, 0)
    end},

    -- 3. ĐI XUYÊN TƯỜNG NGẦU LÒI
    {"👻 Quỷ Ảnh Xuyên Tường", function(root, char)
        -- Kiểm tra xem có đang đứng sát tường không
        local result = workspace:Raycast(root.Position, root.CFrame.LookVector * 4, RaycastParams.new())
        if not result then return end -- Không có tường thì không kích hoạt
        
        PlaySound(231917744, 0.5, root)
        local oldMat = {}
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("BasePart") then
                oldMat[v] = v.Material
                v.Material = Enum.Material.ForceField -- Đổi thành dạng linh hồn
                v.CanCollide = false
            end
        end
        
        -- Dịch chuyển chậm xuyên qua
        local tw = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {CFrame = root.CFrame * CFrame.new(0, 0, -8)})
        tw:Play()
        tw.Completed:Wait()
        
        -- Trả lại hình dáng cũ
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("BasePart") then
                v.Material = oldMat[v] or Enum.Material.Plastic
                v.CanCollide = true
            end
        end
    end},

    -- 4. HÀO QUANG THĂNG THIÊN
    {"✝️ Thánh Quang Hộ Thể", function(root, char, hum)
        PlaySound(142070127, 1.5, root)
        root.Anchored = true
        
        -- Vòng hào quang từ trên trời bắn xuống
        local aura = Instance.new("Part", workspace)
        aura.Shape, aura.Size, aura.Anchored, aura.CanCollide, aura.Material = Enum.PartType.Cylinder, Vector3.new(100, 15, 15), true, false, Enum.Material.Neon
        aura.Color = Color3.fromRGB(255, 215, 0)
        aura.CFrame = root.CFrame * CFrame.Angles(0, 0, math.rad(90)) * CFrame.new(0, 0, 0)
        
        -- Nâng nhân vật lên cao
        TweenService:Create(root, TweenInfo.new(1), {CFrame = root.CFrame * CFrame.new(0, 15, 0)}):Play()
        
        task.wait(5)
        root.Anchored = false
        TweenService:Create(aura, TweenInfo.new(0.5), {Transparency = 1, Size = Vector3.new(100,0,0)}):Play()
        Debris:AddItem(aura, 0.5)
    end},

    -- 5. DỊCH CHUYỂN SAU LƯNG (BACKSTAB)
    {"🗡️ Sát Thủ Phục Kích", function(root, char)
        -- Tìm mục tiêu gần nhất
        local target = nil
        local minDist = 150 -- Tầm quét 150 studs
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    target = p.Character.HumanoidRootPart
                end
            end
        end
        
        if target then
            PlaySound(2248511, 2, root)
            -- Tạo khói tại chỗ cũ
            local smoke = Instance.new("Part", workspace)
            smoke.Size, smoke.CFrame, smoke.Anchored, smoke.Material, smoke.Color = Vector3.new(5,5,5), root.CFrame, true, Enum.Material.Neon, Color3.new(0,0,0)
            TweenService:Create(smoke, TweenInfo.new(0.5), {Size = Vector3.new(0,0,0)}):Play()
            Debris:AddItem(smoke, 0.5)
            
            -- Dịch chuyển ra sau lưng kẻ địch (cách 4 studs)
            root.CFrame = target.CFrame * CFrame.new(0, 0, 4)
            PlaySound(231917744, 1.5, root) -- Tiếng rút kiếm
        end
    end},

    -- 6. TÀNG HÌNH VIP (ẢNH TỬ TRẬN)
    {"🌫️ Ảo Ảnh Hắc Ám (VIP)", function(root, char)
        PlaySound(178452221, 0.5, root)
        
        -- Màn hình xám xịt
        local cc = Instance.new("ColorCorrectionEffect", Lighting)
        cc.Saturation = -1
        cc.Contrast = 0.2
        cc.TintColor = Color3.fromRGB(150, 150, 150)
        
        -- Làm tàng hình cơ thể thật
        local oldTrans = {}
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") then
                oldTrans[v] = v.Transparency
                v.Transparency = 1
            end
        end
        
        -- Vòng lặp tạo bóng trắng đi theo sau
        local timer = 0
        local connection
        connection = RunService.RenderStepped:Connect(function(dt)
            timer = timer + dt
            if timer > 0.1 then -- Cứ 0.1s rớt lại một cái bóng
                CreateGhostTrail(char)
                timer = 0
            end
        end)
        
        task.wait(5)
        
        -- Hủy hiệu ứng
        connection:Disconnect()
        cc:Destroy()
        for v, trans in pairs(oldTrans) do
            if v and v.Parent then v.Transparency = trans end
        end
    end}
}

