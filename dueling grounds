--[[
    👑 MTRIET HYBRID - V16 SERVER CHECK EDITION 👑
    - Kiểm tra Job ID: Nếu đúng server "fb541..." mới kích hoạt chế độ đánh Boss xịn.
    - Server thường: Vẫn chạy Bước 1 nhặt đồ và xả chiêu bình thường.
    - Fix: Logic triệu hồi và đánh Boss không bị xung đột.
]]

local Players = game:GetService("Players")
local VIM = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- =======================================================
-- 🎯 CẤU HÌNH HỆ THỐNG
-- =======================================================
local TARGET_JOB_ID = "fb541321-ec60-43ea-8834-4158fe763129"
local TOA_DO_1 = CFrame.new(732.4, 22.5, -113.8)   -- Bước 1: Nhặt đồ (Triệu hồi)
local TOA_DO_BOSS = CFrame.new(1379.3, -115.2, 64.4) -- Khu vực Boss
local TOA_DO_DICH = CFrame.new(750.7, 18.3, -3.3)    -- Về đích

local BOSS_NAME = "Vua Hắc Ám" 
local AutoCombo = false

-- Hàm xả chiêu E
local function DungChieuE(myTool)
    local char = LocalPlayer.Character
    if myTool and char and char:FindFirstChild("Humanoid") then
        char.Humanoid:UnequipTools()
        task.wait(0.2)
        char.Humanoid:EquipTool(myTool)
        task.wait(0.5)
        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)
        task.wait(3) 
    end
end

-- =======================================================
-- 🎨 GIAO DIỆN RAYFIELD
-- =======================================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "📱 MTRIET HYBRID V16",
    LoadingTitle = "Đang kiểm tra Server...",
    LoadingSubtitle = (game.JobId == TARGET_JOB_ID and "Server Mục Tiêu: KHỚP" or "Server Bình Thường"),
    ConfigurationSaving = { Enabled = false }, 
    KeySystem = false 
})

local TabCombo = Window:CreateTab("👹 Combo Tổng Lực")
local ComboToggle

ComboToggle = TabCombo:CreateToggle({
    Name = "🚀 Chạy Quy Trình (Nhặt & Đánh)", 
    CurrentValue = false, 
    Callback = function(v)
        AutoCombo = v
        if v then
            task.spawn(function()
                while AutoCombo do
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then break end

                    -- BƯỚC 1: TRIỆU HỒI (NHẶT ĐỒ) - Server nào cũng chạy cái này
                    print("▶️ Bước 1: Đang tới điểm nhặt đồ...")
                    hrp.Anchored = false
                    hrp.CFrame = TOA_DO_1
                    task.wait(3) 

                    -- QUÉT TÚI ĐỒ SAU KHI NHẶT
                    local allTools = {}
                    for _, t in ipairs(LocalPlayer:WaitForChild("Backpack"):GetChildren()) do
                        if t:IsA("Tool") then table.insert(allTools, t) end
                    end
                    for _, t in ipairs(char:GetChildren()) do
                        if t:IsA("Tool") then table.insert(allTools, t) end
                    end
                    
                    local ToolSo2 = allTools[2]
                    local ToolSo3 = allTools[3]

                    -- BƯỚC 2: KIỂM TRA SERVER ĐỂ ĐÁNH BOSS
                    if game.JobId == TARGET_JOB_ID then
                        print("✅ Server khớp ID! Tiến hành diệt Boss...")
                        hrp.CFrame = TOA_DO_BOSS
                        task.wait(5) -- Đợi Boss hiện

                        local targetBoss = workspace:FindFirstChild(BOSS_NAME, true)
                        if targetBoss and targetBoss:FindFirstChild("HumanoidRootPart") then
                            local bossHRP = targetBoss.HumanoidRootPart
                            bossHRP.Size = Vector3.new(50, 50, 50) -- Max Hitbox
                            
                            if ToolSo2 then DungChieuE(ToolSo2) end
                            if ToolSo3 then DungChieuE(ToolSo3) end
                        end
                    else
                        -- NẾU LÀ SERVER THƯỜNG: Chỉ xả chiêu tại chỗ hoặc bỏ qua bước đánh Boss
                        Rayfield:Notify({Title = "Server Thường", Content = "Bỏ qua bước đánh Boss theo ID.", Duration = 3})
                        task.wait(1)
                    end

                    -- BƯỚC CUỐI: VỀ ĐÍCH
                    print("▶️ Kết thúc quy trình.")
                    hrp.Anchored = false
                    hrp.CFrame = TOA_DO_DICH
                    task.wait(0.1)
                    hrp.Anchored = true 
                    
                    AutoCombo = false
                    ComboToggle:Set(false) 
                    break 
                end
            end)
        end
    end
})

-- Tự động thông báo khi vào đúng server
if game.JobId == TARGET_JOB_ID then
    Rayfield:Notify({
        Title = "🎯 Đã vào Server Mục Tiêu!",
        Content = "Chế độ diệt Boss đặc biệt đã sẵn sàng.",
        Duration = 10
    })
end
