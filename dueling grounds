--[[
    👑 MTRIET VIP HUB - ULTIMATE V2 (HIT & RUN EDITION) 👑
    Cập nhật: Bổ nhào từ trên trời, Sửa lỗi nhặt đồ trang trí, Fix Auto YES.
]]

local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

local AutoTour, AutoSkillTour, AutoGom = false, false, false
local SafeCFrame = nil 

local function LoadMainHub()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({
        Name = "👑 MTRIET VIP - V2 HIT & RUN",
        LoadingTitle = "Đang nạp hệ thống...",
        LoadingSubtitle = "Bản vá lỗi nhặt đồ & Combo Ẩu",
        ConfigurationSaving = { Enabled = true, FolderName = "MTRIET_VIP", FileName = "Config" },
        KeySystem = false 
    })

    -- ==========================================
    -- 🌋 TAB: GIẢI ĐẤU & COMBAT ẨU
    -- ==========================================
    local TabAuto = Window:CreateTab("🌋 Giải Đấu Sinh Tử")

    TabAuto:CreateToggle({Name = "1. Auto Bấm YES (Vô Giải)", CurrentValue = false, Callback = function(v)
        AutoTour = v
        task.spawn(function()
            while AutoTour do
                task.wait(0.5) -- Quét nhanh hơn
                pcall(function()
                    local pGui = LocalPlayer:WaitForChild("PlayerGui")
                    for _, gui in ipairs(pGui:GetDescendants()) do
                        -- Quét rộng hơn để tránh xịt UI
                        if gui:IsA("TextButton") and (string.match(gui.Name:lower(), "yes") or string.match(gui.Text:lower(), "yes")) then
                            if gui.AbsolutePosition.X > 0 and gui.AbsolutePosition.Y > 0 then -- Đảm bảo UI đang hiện trên màn hình
                                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                    SafeCFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                                end
                                for _, connection in pairs(getconnections(gui.MouseButton1Click)) do 
                                    connection:Fire() 
                                end
                            end
                        end
                    end
                end)
            end
        end)
    end})

    TabAuto:CreateToggle({Name = "2. Bật Combo Ẩu (Tàng Hình + Bay Lên + Gõ Xuống)", CurrentValue = false, Callback = function(v)
        AutoSkillTour = v
        
        -- Kích hoạt tàng hình khi bật
        if AutoSkillTour and LocalPlayer.Character then
            for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do 
                if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 1 end 
            end
        end

        task.spawn(function()
            while AutoSkillTour do
                task.wait(0.05) -- Tốc độ vòng lặp cực nhanh để giật hit & run
                if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then continue end
                local myHRP = LocalPlayer.Character.HumanoidRootPart
                local bestTarget = nil
                local shortestDist = 5000

                -- Tìm mục tiêu (Sống & Không bị rơi vực)
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
                        local targetHRP = p.Character.HumanoidRootPart
                        local targetHum = p.Character.Humanoid
                        -- Check máu và vận tốc rơi (né mấy thằng đang rớt đài)
                        if targetHum.Health > 0 and targetHRP.Velocity.Y > -45 then
                            local dist = (targetHRP.Position - myHRP.Position).Magnitude
                            if dist < shortestDist then
                                shortestDist = dist
                                bestTarget = targetHRP
                            end
                        end
                    end
                end

                if bestTarget then
                    -- 1. Phóng to hitbox tối đa
                    bestTarget.Size = Vector3.new(50, 50, 50)
                    bestTarget.Transparency = 0.8
                    bestTarget.CanCollide = false
                    
                    -- 2. Đảo vị trí: Treo trên đầu địch (Y+50) để an toàn
                    myHRP.CFrame = bestTarget.CFrame * CFrame.new(0, 50, 0)
                    myHRP.Velocity = Vector3.zero
                    task.wait(0.1) 
                    
                    -- 3. Bổ nhào xuống gõ
                    if AutoSkillTour then -- Tránh trường hợp tắt đột ngột
                        myHRP.CFrame = bestTarget.CFrame * CFrame.new(0, 0, 3)
                        -- Spam vũ khí
                        for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
                            if tool:IsA("Tool") then
                                LocalPlayer.Character.Humanoid:EquipTool(tool)
                                tool:Activate()
                            end
                        end
                    end
                else
                    -- Không có địch thì về chỗ an toàn
                    if SafeCFrame then
                        myHRP.CFrame = SafeCFrame + Vector3.new(0, 50, 0) -- Đứng tạm trên không
                    end
                end
            end
            
            -- Trả lại hình dáng khi tắt
            if not AutoSkillTour and LocalPlayer.Character then
                for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do 
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = 0 end 
                end
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                    end
                end
            end
        end)
    end})

    -- ==========================================
    -- 💎 TAB: MÁY HÚT LINH HỒN
    -- ==========================================
    local TabDrop = Window:CreateTab("💎 Máy Lượm")

    TabDrop:CreateToggle({
        Name = "Hút Kim Cương & Linh Hồn (Đã Fix Hàng Fake)",
        CurrentValue = false,
        Callback = function(v)
            AutoGom = v
            task.spawn(function()
                while AutoGom do
                    task.wait(0.1) 
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = LocalPlayer.Character.HumanoidRootPart
                        local oldPos = hrp.CFrame 
                        
                        for _, item in ipairs(workspace:GetDescendants()) do
                            local itemName = item.Name:lower()
                            if itemName == "diamond" or itemName == "drop" or string.match(itemName, "soul") then
                                if item:IsA("BasePart") then
                                    -- CHỐNG LỎ: Chỉ dịch chuyển nếu part có TouchInterest (hàng thật)
                                    if item:FindFirstChild("TouchInterest") or item:FindFirstChildWhichIsA("ProximityPrompt") then
                                        hrp.CFrame = item.CFrame
                                        task.wait(0.05)
                                        
                                        if item:FindFirstChild("TouchInterest") and firetouchinterest then
                                            firetouchinterest(hrp, item, 0)
                                            task.wait()
                                            firetouchinterest(hrp, item, 1)
                                        end
                                        
                                        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt")
                                        if prompt and fireproximityprompt then
                                            fireproximityprompt(prompt)
                                        end
                                        
                                        hrp.CFrame = oldPos -- Giật về
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    })
end

LoadMainHub()
