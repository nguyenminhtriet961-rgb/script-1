-- Biến quản lý trạng thái Từng Nút (Cho phép bật nhiều cái cùng lúc)
local Toggles = {
    ["Tự Đánh Nhào Lên"] = false,
    ["Tự Đỡ (Parry)"] = false,
    ["Khóa Mục Tiêu"] = false,
    ["Xuyên Tường (ESP)"] = false
}

-- Hàm tạo Nút bấm
local function CreateToggleButton(name, yPos)
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0.9, 0, 0, 30)
    Btn.Position = UDim2.new(0.05, 0, 0, yPos)
    Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Btn.Font = Enum.Font.GothamBold
    Btn.Text = name .. " [TẮT]"
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.TextSize = 13
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    
    Btn.MouseButton1Click:Connect(function()
        Toggles[name] = not Toggles[name]
        if Toggles[name] then
            Btn.BackgroundColor3 = Color3.fromRGB(0, 200, 50) 
            Btn.Text = name .. " [BẬT]"
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Btn.Text = name .. " [TẮT]"
            Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            
            -- Xóa ESP ngay lập tức nếu tắt
            if name == "Xuyên Tường (ESP)" then
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character and p.Character:FindFirstChild("MTRIET_ESP") then
                        p.Character.MTRIET_ESP:Destroy()
                    end
                end
            end
        end
    end)
    return Btn
end

CreateToggleButton("Tự Đánh Nhào Lên", 40)
CreateToggleButton("Tự Đỡ (Parry)", 75)
CreateToggleButton("Khóa Mục Tiêu", 110)
CreateToggleButton("Xuyên Tường (ESP)", 145)

-- ==========================================
-- VÒNG LẶP XỬ LÝ CHUNG (HEARTBEAT MƯỢT MÀ)
-- ==========================================

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or char.Humanoid.Health <= 0 then return end
    
    local myHRP = char.HumanoidRootPart
    local equippedTool = char:FindFirstChildOfClass("Tool")
    
    local closestTarget = nil
    local shortestDist = 30 -- Khoảng cách quét chung

    -- Tìm mục tiêu gần nhất
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local dist = (p.Character.HumanoidRootPart.Position - myHRP.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestTarget = p.Character
            end
            
            -- Chức năng ESP Xuyên Tường
            if Toggles["Xuyên Tường (ESP)"] and not p.Character:FindFirstChild("MTRIET_ESP") then
                local hl = Instance.new("Highlight")
                hl.Name = "MTRIET_ESP"
                hl.FillColor = Color3.fromRGB(255, 0, 0)
                hl.FillTransparency = 0.5
                hl.Parent = p.Character
            end
        end
    end

    if closestTarget then
        -- 1. Khóa Mục Tiêu (Aim Assist)
        if Toggles["Khóa Mục Tiêu"] then
            local targetPos = closestTarget.HumanoidRootPart.Position
            local lookAtCFrame = CFrame.new(myHRP.Position, Vector3.new(targetPos.X, myHRP.Position.Y, targetPos.Z))
            myHRP.CFrame = myHRP.CFrame:Lerp(lookAtCFrame, 0.2)
        end

        -- 2. Tự Đỡ (Parry) - Ưu tiên phòng thủ nếu địch quá gần (dưới 10 stud)
        if Toggles["Tự Đỡ (Parry)"] and shortestDist < 10 then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.01)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end

        -- 3. Tự Đánh (Auto M1) - Chém nếu nằm trong tầm kiếm
        if Toggles["Tự Đánh Nhào Lên"] and equippedTool and shortestDist < 12 then
            equippedTool:Activate()
        end
    end
end)

-- Tắt các chức năng khi hồi sinh để tránh lỗi kẹt script
LocalPlayer.CharacterAdded:Connect(function()
    for key, _ in pairs(Toggles) do
        Toggles[key] = false
    end
    for _, child in ipairs(Frame:GetChildren()) do
        if child:IsA("TextButton") and child.Name ~= "Close" then
            child.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            local rawName = child.Text:match("(.*) %[")
            child.Text = rawName .. " [TẮT]"
            child.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
    end
end)
