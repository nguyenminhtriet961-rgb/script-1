                    local bolt = Instance.new("Part", workspace)
                    bolt.Size, bolt.CFrame, bolt.Anchored, bolt.CanCollide = Vector3.new(0.5, 0.5, dist), CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -dist/2), true, false
