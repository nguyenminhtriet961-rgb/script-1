-- ==========================================
    -- 🌌 TAB: COMBO KHÔNG GIAN (LOGIC TỐI ƯU CỦA CHỊ MINT)
    -- ==========================================
    local TabKhongGian = Window:CreateTab("🌌 Combo Boss")
    local AutoVoidCustom = false
    local VIM = game:GetService("VirtualInputManager")

    -- [!] CHỊ MINT NHỚ LẤY TỌA ĐỘ BẰNG NÚT F9 VÀ ĐIỀN VÀO 3 DÒNG NÀY:
    local TOA_DO_TRAI_VOID = CFrame.new(0, 100, 0) -- Điểm 1: Nơi trái bóng tối xuất hiện
    local TOA_DO_DUNG_VP2  = CFrame.new(0, 100, 0) -- Điểm 2: Nơi chị muốn đứng để xả chiêu VP 2
    local TOA_DO_DUNG_VP3  = CFrame.new(0, 100, 0) -- Điểm 3: Nơi chị muốn đứng để xả chiêu VP 3

    local function TrangBiVaBamE(viTriItem)
        local backpack = LocalPlayer:WaitForChild("Backpack")
        local tools = backpack:GetChildren()
        
        if tools[viTriItem] and tools[viTriItem]:IsA("Tool") then
            -- Trang bị vũ khí
            LocalPlayer.Character.Humanoid:EquipTool(tools[viTriItem])
            task.wait(0.5)
            
            -- Ép hệ thống nhận diện phím E (Chống kẹt chiêu)
            VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            task.wait(0.5)
        end
    end

    TabKhongGian:CreateToggle({
        Name = "Khởi chạy Combo Tự Động", 
        CurrentValue = false, 
        Callback = function(v)
            AutoVoidCustom = v
            task.spawn(function()
                while AutoVoidCustom do
                    task.wait(1)
                    local char = LocalPlayer.Character
                    if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
                    local hrp = char.HumanoidRootPart

                    -- BƯỚC 1: Dịch chuyển lấy trái bóng tối
                    hrp.CFrame = TOA_DO_TRAI_VOID
                    task.wait(1.5) -- Đợi 1.5s để server ghi nhận đã nhặt được

                    -- BƯỚC 2: Dịch chuyển tới tọa độ chỉ định thứ nhất
                    hrp.CFrame = TOA_DO_DUNG_VP2
                    task.wait(0.5) -- Khựng lại một nhịp cho ổn định vật lý

                    -- BƯỚC 3: Cầm vật phẩm 2 và bấm E
                    TrangBiVaBamE(2)
                    task.wait(1) -- Đợi hiệu ứng chiêu xuất hiện

                    -- BƯỚC 4: Dịch chuyển tới tọa độ chỉ định thứ hai
                    hrp.CFrame = TOA_DO_DUNG_VP3
                    task.wait(0.5)

                    -- BƯỚC 5: Cầm vật phẩm 3 và bấm E
                    TrangBiVaBamE(3)
                    task.wait(2) -- Nghỉ ngơi xả chiêu xong trước khi lặp lại vòng mới
                    
                end
            end)
        end
    })
