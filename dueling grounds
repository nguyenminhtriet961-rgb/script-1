local function PlaySound(id, pitch, vol)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = vol or 2; s.Pitch = pitch or 1; s.Parent = player.Character.HumanoidRootPart
    s:Play(); Debris:AddItem(s, 5)
end

local function CreateGhostTrail(char)
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = part:Clone()
            clone.Parent = workspace; clone.Anchored = true; clone.CanCollide = false
            clone.Material = Enum.Material.ForceField; clone.Color = Color3.new(1, 1, 1)
            TweenService:Create(clone, TweenInfo.new(0.5), {Transparency = 1}):Play()
            Debris:AddItem(clone, 0.5)
        end
    end
end

local function Earthquake(duration, intensity)
    task.spawn(function()
        local start = tick()
        while tick() - start < duration do
            Camera.CFrame = Camera.CFrame * CFrame.new(
                math.random(-10, 10) * 0.01 * intensity,
                math.random(-10, 10) * 0.01 * intensity,
                math.random(-10, 10) * 0.01 * intensity
            )
            task.wait()
        end
    end)
end
local HeavyScreenShake = Earthquake

local function CreateParticleCore(cf)
    local core = Instance.new("Part", workspace)
    core.Size, core.Transparency, core.Anchored, core.CanCollide = Vector3.new(1,1,1), 1, true, false
    core.CFrame = cf
    return core
end

