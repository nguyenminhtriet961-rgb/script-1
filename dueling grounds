TabMain:CreateSection("Bấm vào để nhận vũ khí")

for _, item in ipairs(Arsenal) do
    TabMain:CreateButton({
        Name = "Nhận: " .. item[1],
        Callback = function()
            if not player.Backpack:FindFirstChild(item[1]) then
                local tool = Instance.new("Tool", player.Backpack)
                tool.Name, tool.RequiresHandle = item[1], false
                tool.Activated:Connect(function()
                    local char = player.Character
                    if not char or not char:FindFirstChild("HumanoidRootPart") or _G.IsCasting then return end
                    _G.IsCasting = true
                    item[2](char.HumanoidRootPart, char, char:FindFirstChild("Humanoid"))
                    task.wait(0.5) -- Tránh spam
                    _G.IsCasting = false
                end)
            end
        end
    })
end

TabMain:CreateButton({
    Name = "🧹 Xóa tất cả vật phẩm",
    Callback = function()
        for _, v in pairs(player.Backpack:GetChildren()) do v:Destroy() end
        if player.Character then 
            for _, v in pairs(player.Character:GetChildren()) do if v:IsA("Tool") then v:Destroy() end end 
        end
    end
})
