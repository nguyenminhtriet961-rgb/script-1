                    p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                    p.Character.HumanoidRootPart.Transparency = 0
                end
            end
        end

        task.spawn(function()
            while AuraOn do
                RunService.Heartbeat:Wait()
                if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then continue end
                local myHRP = LocalPlayer.Character.HumanoidRootPart
                
                local targetHRP = nil
                local dist = AuraScanRange

                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
                        if p.Character.Humanoid.Health > 0 and p.Character.HumanoidRootPart.Velocity.Y > -45 then
                            local d = (p.Character.HumanoidRootPart.Position - myHRP.Position).Magnitude
                            if d < dist then dist = d; targetHRP = p.Character.HumanoidRootPart end
                        end
                    end
                end

                if targetHRP then
                    -- Hiện Hitbox đỏ
                    targetHRP.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                    targetHRP.Transparency = 0.5
                    targetHRP.BrickColor = BrickColor.new("Bright red")
                    targetHRP.CanCollide = false
                    
                    -- CHỐNG QUAY MÒNG MÒNG: Chỉ lấy Vị trí (Position) cộng thêm độ cao (Y), không lấy góc xoay.
                    myHRP.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, AuraOffsetDist, 0))
                    
                    if tick() - lastAtkTime >= AuraAtkSpeed then
                        lastAtkTime = tick()
                        for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
                            if tool:IsA("Tool") then
                                LocalPlayer.Character.Humanoid:EquipTool(tool)
                                tool:Activate()
                            end
                        end
                    end
                end
            end
        end)
    end})

    TabAura:CreateSlider({Name = "Hitbox Kẻ Địch", Range = {5, 50}, Increment = 1, CurrentValue = 15, Callback = function(v) HitboxSize = v end})
    TabAura:CreateSlider({Name = "Tốc độ chém (Giây/Nhát, 0=MAX)", Range = {0, 1}, Increment = 0.01, CurrentValue = 0, Callback = function(v) AuraAtkSpeed = v end})
    TabAura:CreateSlider({Name = "Độ cao đứng trên đỉnh đầu", Range = {1, 20}, Increment = 1, CurrentValue = 5, Callback = function(v) AuraOffsetDist = v end})
    TabAura:CreateSlider({Name = "Bán kính quét (Stud)", Range = {50, 5000}, Increment = 50, CurrentValue = 5000, Callback = function(v) AuraScanRange = v end})

    -- ==========================================
    -- 💎 TAB 4: MÁY LƯỢM (ANCHOR FIXED)
    -- ==========================================
    local TabDrop = Window:CreateTab("💎 Máy Lượm")

    TabDrop:CreateDropdown({
        Name = "Chọn Chế Độ Nhặt",
        Options = {"Tắt", "Chế độ 1: Bay lại nhặt", "Chế độ 2: Teleport nhặt", "Chế độ 3: AFK Trên Trời (Fix rớt)"},
        CurrentOption = {"Tắt"},
        Callback = function(Option)
            if Option[1] == "Tắt" then 
                AutoGomMode = 0
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.Anchored = false
                end
            elseif Option[1] == "Chế độ 1: Bay lại nhặt" then 
                AutoGomMode = 1
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.Anchored = false end
            elseif Option[1] == "Chế độ 2: Teleport nhặt" then 
                AutoGomMode = 2
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.Anchored = false end
            elseif Option[1] == "Chế độ 3: AFK Trên Trời (Fix rớt)" then 
                AutoGomMode = 3
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    AFK_SkyPos = LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(0, 500, 0)
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(AFK_SkyPos)
                    LocalPlayer.Character.HumanoidRootPart.Anchored = true
                end
            end
        end,
    })

    task.spawn(function()
        while true do
            task.wait(0.1)
            if AutoGomMode == 0 then continue end
            
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            for _, item in ipairs(workspace:GetDescendants()) do
                local itemName = item.Name:lower()
                if (itemName == "diamond" or itemName == "drop" or itemName:match("soul")) and item:IsA("BasePart") then
                    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt")
                    local touch = item:FindFirstChild("TouchInterest")

                    if AutoGomMode == 1 and (prompt or touch) then
                        hrp.CFrame = item.CFrame * CFrame.new(0, 2, 0)
                        task.wait(0.2)
                        if prompt then fireproximityprompt(prompt) end
                    elseif AutoGomMode == 2 and (prompt or touch) then
                        local old = hrp.CFrame
                        hrp.CFrame = item.CFrame
                        task.wait(0.05)
                        if prompt then fireproximityprompt(prompt) end
                        hrp.CFrame = old
                    elseif AutoGomMode == 3 and (prompt or touch) then
                        hrp.Anchored = false
                        hrp.CFrame = item.CFrame
                        task.wait(0.05)
                        if prompt then fireproximityprompt(prompt) end
                        if touch and firetouchinterest then
                            firetouchinterest(hrp, item, 0)
                            task.wait()
                            firetouchinterest(hrp, item, 1)
                        end
                        -- Trở về vị trí đóng băng trên trời
                        hrp.CFrame = CFrame.new(AFK_SkyPos)
                        hrp.Anchored = true
                    end
                end
            end
        end
    end)

    -- ==========================================
    -- ⏳ TAB 5: FLY MOBILE & TIỆN ÍCH
