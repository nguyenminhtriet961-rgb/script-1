-- 💎 TAB 3: MÁY LƯỢM ĐỒ
-- ==========================================
local TabDrop = Window:CreateTab("💎 Nhặt Đồ")

TabDrop:CreateDropdown({
    Name = "Chế Độ Nhặt (Kim Cương/Hư Không)",
    Options = {"Tắt", "1. Bay lại nhặt", "2. Teleport nhặt", "3. Neo trên trời"},
    CurrentOption = {"Tắt"},
    Callback = function(Option)
        if Option[1] == "Tắt" then 
            AutoGomMode = 0
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.Anchored = false
            end
        elseif Option[1] == "1. Bay lại nhặt" then 
            AutoGomMode = 1
        elseif Option[1] == "2. Teleport nhặt" then 
            AutoGomMode = 2
        elseif Option[1] == "3. Neo trên trời" then 
            AutoGomMode = 3
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                AFK_SkyPos = LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(0, 500, 0)
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(AFK_SkyPos)
                LocalPlayer.Character.HumanoidRootPart.Anchored = true
            end
        end
    end,
})

task.spawn(function()
    while true do
        task.wait(0.1)
        if AutoGomMode == 0 then continue end
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        for _, item in ipairs(workspace:GetDescendants()) do
            local itemName = item.Name:lower()
            if (itemName == "diamond" or itemName == "drop" or itemName:match("soul") or itemName:match("void")) and item:IsA("BasePart") then
                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt")
                local touch = item:FindFirstChild("TouchInterest")

                if (prompt or touch) then
                    if AutoGomMode == 1 then
                        hrp.CFrame = item.CFrame * CFrame.new(0, 2, 0)
                        task.wait(0.2)
                    elseif AutoGomMode == 2 then
                        local old = hrp.CFrame
                        hrp.CFrame = item.CFrame
                        task.wait(0.05)
                        hrp.CFrame = old
                    elseif AutoGomMode == 3 then
                        hrp.Anchored = false
                        hrp.CFrame = item.CFrame
                        task.wait(0.05)
                    end

                    if prompt then fireproximityprompt(prompt) end
                    if touch and firetouchinterest then
                        firetouchinterest(hrp, item, 0)
                        task.wait()
                        firetouchinterest(hrp, item, 1)
                    end

                    if AutoGomMode == 3 then
                        hrp.CFrame = CFrame.new(AFK_SkyPos)
                        hrp.Anchored = true
                    end
                end
            end
        end
    end
end)

-- ==========================================
-- 👹 TAB 4: COMBO DIỆT BOSS
-- ==========================================
local TabBoss = Window:CreateTab("👹 Boss Slayer")
local ComboToggle

ComboToggle = TabBoss:CreateToggle({
    Name = "🚀 Kích Hoạt Triệu Hồi & Diệt Boss", 
    CurrentValue = false, 
    Callback = function(v)
        AutoComboBoss = v
        if v then
            task.spawn(function()
                while AutoComboBoss do
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then break end

                    -- BƯỚC 1: TRIỆU HỒI / LẤY TRÁI
                    print("▶️ Bước 1: Triệu hồi / Lấy vật phẩm...")
                    hrp.Anchored = false
                    hrp.CFrame = TOA_DO_1
                    task.wait(3) 

                    -- CHỐT SỔ TÚI ĐỒ (Lấy object để spam)
                    local allTools = {}
                    for _, t in ipairs(LocalPlayer:WaitForChild("Backpack"):GetChildren()) do
                        if t:IsA("Tool") then table.insert(allTools, t) end
                    end
                    for _, t in ipairs(char:GetChildren()) do
                        if t:IsA("Tool") then table.insert(allTools, t) end
                    end
                    local ToolSo2 = allTools[2]

                    -- BƯỚC 2: KIỂM TRA SERVER ĐỂ DIỆT BOSS
                    if game.JobId == TARGET_JOB_ID then
                        print("🎯 Server Khớp! Đang tới khu vực Boss...")
                        hrp.CFrame = TOA_DO_BOSS
                        task.wait(5) -- Đợi 5 giây Boss xuất hiện

                        local boss = workspace:FindFirstChild(BOSS_NAME, true)
                        if boss and boss:FindFirstChild("HumanoidRootPart") then
                            local bossHRP = boss.HumanoidRootPart
                            bossHRP.Size = Vector3.new(60, 60, 60) -- Max Hitbox
                            bossHRP.CanCollide = false
                            
                            print("⚔️ Bắt đầu Orbit và Spam đánh thường VP 2...")
                            hrp.Anchored = true -- Giữ nguyên trọng lực (thăng bằng)
                            
                            -- Vòng lặp xoay quanh Boss và chém
                            local startTime = tick()
                            while AutoComboBoss and boss.Parent and (tick() - startTime < 15) do -- Orbit trong 15s hoặc đến khi Boss chết
                                RunService.Heartbeat:Wait()
                                orbitAngle = orbitAngle + math.rad(ORBIT_SPEED)
                                
                                -- Xoay tròn xung quanh Boss
                                local offset = Vector3.new(math.cos(orbitAngle) * ORBIT_RADIUS, 5, math.sin(orbitAngle) * ORBIT_RADIUS)
                                hrp.CFrame = CFrame.new(bossHRP.Position + offset, bossHRP.Position)
                                
                                -- Spam đánh thường VP 2
                                if ToolSo2 then
                                    char.Humanoid:EquipTool(ToolSo2)
                                    pcall(function() ToolSo2:Activate() end) -- Mô phỏng chạm màn hình đánh thường
                                end
                            end
                        else
                            warn("⚠️ Không thấy Boss King!")
                        end
                    else
                        print("⏩ Server Thường. Bỏ qua bước diệt Boss.")
                        task.wait(1)
                    end

                    -- BƯỚC CUỐI: RÚT LUI
                    print("▶️ Về đích an toàn...")
                    hrp.Anchored = false
                    hrp.CFrame = TOA_DO_DICH
                    task.wait(0.2)
                    hrp.Anchored = true 
                    
                    AutoComboBoss = false
                    ComboToggle:Set(false) 
                    Rayfield:Notify({Title = "Hoàn tất!", Content = "Quy trình đã kết thúc.", Duration = 5})
                    break 
                end
            end)
        else
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.Anchored = false
            end
        end
    end
})

