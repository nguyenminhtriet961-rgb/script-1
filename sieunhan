-- ==========================================
-- HÀM HỖ TRỢ VFX & AUDIO
-- ==========================================
local function PlaySound(id, pitch, vol)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = vol or 2; s.Pitch = pitch or 1; s.Parent = player.Character and player.Character:FindFirstChild("HumanoidRootPart") or workspace
    s:Play(); Debris:AddItem(s, 5)
end

-- Hàm tạo tàn ảnh (Ghost Trail)
local function CreateGhostTrail(char, duration, color)
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = part:Clone()
            clone.Parent = workspace
            clone.Anchored = true; clone.CanCollide = false
            clone.Material = Enum.Material.ForceField
            clone.Color = color or Color3.fromRGB(150, 255, 255)
            
            -- Xóa các thành phần thừa trong clone
            for _, v in pairs(clone:GetChildren()) do
                if not v:IsA("SpecialMesh") then v:Destroy() end
            end
            
            TweenService:Create(clone, TweenInfo.new(duration or 0.5), {Transparency = 1}):Play()
            Debris:AddItem(clone, duration or 0.5)
        end
    end
end

-- ==========================================
-- 1. BIẾN HÌNH MA THẦN (AURA V4)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: 🔮 Ấn Ký Ma Thần (Biến Hình)",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "🔮 Ấn Ký Ma Thần", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            if _G.IsMaThan then
                Rayfield:Notify({Title = "Nhắc nhở", Content = "Đã biến hình rồi má!", Duration = 2})
                return
            end
            
            _G.IsMaThan = true
            
            -- Dừng mọi animation cầm đồ lỏ
            for _, anim in pairs(hum:GetPlayingAnimationTracks()) do anim:Stop() end
            
            -- AUDIO VIP
            PlaySound(142070127, 0.4, 3) -- Nổ trầm
            PlaySound(178452221, 0.5, 2) -- Gió rít
            PlaySound(2248511, 0.2, 1.5) -- Tĩnh điện hắc khí
            
            -- Màn hình xám xịt
            local cc = Instance.new("ColorCorrectionEffect", Lighting)
            cc.Name = "MaThanCC"
            TweenService:Create(cc, TweenInfo.new(1), {Saturation = -1, Contrast = 0.2, TintColor = Color3.fromRGB(200, 200, 200)}):Play()
            
            -- Animation Biến Hình: Bay lên và Xoay vòng
            root.Anchored = true
            local twTransform = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Exponential), {CFrame = root.CFrame * CFrame.new(0, 8, 0) * CFrame.Angles(0, math.rad(360*2), 0)})
            twTransform:Play()
            twTransform.Completed:Wait()
            root.Anchored = false
            
            -- Lơ lửng khi di chuyển (Bằng cách hack HipHeight thay vì BodyVelocity)
            hum.HipHeight = 5 -- Lơ lửng cách đất 5 studs
            hum.WalkSpeed = 50 -- Chạy tốc độ thần thánh
            
            -- AURA KIỂU V4 BLOX FRUITS (Không dùng Clone dính người nữa)
            -- Lớp 1: Hơi thở trắng rực rỡ tỏa ra
            local auraWhite = Instance.new("ParticleEmitter", root)
            auraWhite.Name = "V4AuraWhite"
            auraWhite.Texture = "rbxassetid://504653048" -- Ring texture
            auraWhite.Color = ColorSequence.new(Color3.new(1, 1, 1))
            auraWhite.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.5, 8), NumberSequenceKeypoint.new(1, 0)})
            auraWhite.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.5, 0.2), NumberSequenceKeypoint.new(1, 1)})
            auraWhite.Lifetime = NumberRange.new(1)
            auraWhite.Rate = 20
            auraWhite.Speed = NumberRange.new(0)
            auraWhite.Rotation = NumberRange.new(0, 360)
            auraWhite.RotSpeed = NumberRange.new(-50, 50)
            auraWhite.LockedToPart = true
            
            -- Lớp 2: Hắc khí lỗi rỉ ra xung quanh
            local auraBlack = Instance.new("ParticleEmitter", root)
            auraBlack.Name = "V4AuraBlack"
            auraBlack.Texture = "rbxassetid://243660364"
            auraBlack.Color = ColorSequence.new(Color3.new(0, 0, 0))
            auraBlack.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 2), NumberSequenceKeypoint.new(1, 5)})
            auraBlack.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
            auraBlack.Lifetime = NumberRange.new(0.5, 1)
            auraBlack.Rate = 80
            auraBlack.Speed = NumberRange.new(2, 5)
            auraBlack.SpreadAngle = Vector2.new(360, 360)
            
            -- Vòng lặp: Di chuyển tạo tàn ảnh ảo
            local timer = 0
            ghostMovementConn = RunService.RenderStepped:Connect(function(dt)
                timer = timer + dt
                if timer > 0.1 and hum.MoveDirection.Magnitude > 0 then 
                    CreateGhostTrail(char, 0.6, Color3.fromRGB(200, 200, 200)) -- Tàn ảnh xám trắng ngầu
                    timer = 0 
                end
            end)
            
            Rayfield:Notify({Title = "Thức tỉnh!", Content = "Ma Thần Hóa V4 thành công!", Duration = 3})
        end)
    end
})

-- ==========================================
-- 2. BƯỚC NHẢY KHÔNG GIAN (LƯỚT 50M)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: ⚡ Kỹ Năng: Bước Nhảy Không Gian",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "⚡ Bước Nhảy Không Gian", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            
            if not _G.IsMaThan then
                Rayfield:Notify({Title = "Cảnh báo", Content = "Phải thức tỉnh Ma Thần mới nhảy được!", Duration = 2})
                return
            end
            
            local root = char.HumanoidRootPart
            PlaySound(231917744, 0.8, 2) -- Tiếng xé gió
            PlaySound(12222208, 1.5, 1)  -- Kèm tiếng nổ sấm
            
            -- Xác định điểm lướt (Phía trước mặt 50m để 100% chuẩn trên điện thoại)
            local startPos = root.Position
            local dashVector = root.CFrame.LookVector * 50
            
            -- Check tường tránh đâm xuyên map lỏ
            local ray = workspace:Raycast(startPos, dashVector, RaycastParams.new())
            local targetPos = ray and ray.Position or (startPos + dashVector)
            local actualDist = (targetPos - startPos).Magnitude
            
            TweenService:Create(Camera, TweenInfo.new(0.1, Enum.EasingStyle.Exponential), {FieldOfView = 110}):Play()
            
            -- Hiệu ứng tia sáng siêu ngầu quét qua
            local beam = Instance.new("Part", workspace)
            beam.Size = Vector3.new(2, 2, actualDist)
            beam.CFrame = CFrame.lookAt(startPos, targetPos) * CFrame.new(0, 0, -actualDist/2)
            beam.Anchored = true; beam.CanCollide = false
            beam.Material = Enum.Material.Neon; beam.Color = Color3.new(1, 1, 1)
            TweenService:Create(beam, TweenInfo.new(0.3), {Size = Vector3.new(0,0,actualDist), Transparency = 1}):Play()
            Debris:AddItem(beam, 0.3)
            
            -- Tween lướt tới
            local tw = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos, targetPos + dashVector)})
            tw:Play()
            
            -- Xả tàn ảnh liên tục siêu tốc
            task.spawn(function()
                while tw.PlaybackState == Enum.PlaybackState.Playing do
                    CreateGhostTrail(char, 0.3, Color3.new(1,1,1))
                    task.wait(0.01)
                end
            end)
            
            tw.Completed:Wait()
            TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {FieldOfView = 70}):Play()
        end)
    end
})

-- ==========================================
-- 3. HỦY DẠNG MA THẦN
-- ==========================================
TabTrans:CreateButton({
    Name = "❌ Hủy Dạng Ma Thần",
    Callback = function()
        _G.IsMaThan = false
        local char = player.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            
            if hum then 
                hum.WalkSpeed = 16 
                hum.HipHeight = 0 -- Trả lại độ cao bình thường
            end
            
            if root then 
                if root:FindFirstChild("V4AuraWhite") then root.V4AuraWhite:Destroy() end
                if root:FindFirstChild("V4AuraBlack") then root.V4AuraBlack:Destroy() end
            end
        end
        if ghostMovementConn then ghostMovementConn:Disconnect() end
        if Lighting:FindFirstChild("MaThanCC") then Lighting.MaThanCC:Destroy() end
        Rayfield:Notify({Title = "Thông báo", Content = "Đã thu hồi pháp lực.", Duration = 2})
    end
})
