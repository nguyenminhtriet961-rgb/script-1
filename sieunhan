-- 2. CỔNG XUYÊN KHÔNG 100M (DỰNG ĐỨNG TRƯỚC MẶT)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: 🌀 Cổng Xuyên Không (100m)",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "🌀 Cổng 100m", false
        local isCasting = false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") or isCasting or not _G.IsMaThan then return end
            
            isCasting = true
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            PlaySound(142070127, 0.5, 3)
            
            local startPos = root.Position
            local dashDirection = root.CFrame.LookVector
            local targetPos = startPos + (dashDirection * 100)
            
            -- Cổng Dựng Đứng Trước Mặt (Cách 5m)
            local p1, a1 = SpawnFrontPortal(startPos, dashDirection, Color3.fromRGB(0, 255, 100))
            task.spawn(function() for i=1, 10 do StrikeLightning(p1.Position, 15, Color3.fromRGB(0, 255, 100)); task.wait(0.1) end end)
            
            hum.WalkSpeed = 0 
            -- Tự động đi thẳng vào giữa cổng
            TweenService:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = root.CFrame + dashDirection * 5}):Play()
            task.wait(0.5)
            
            for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.Transparency = 1 end end
            p1:Destroy(); a1:Destroy()
            
            local blur = Instance.new("BlurEffect", Lighting); blur.Size = 40
            task.spawn(function()
                for i = 1, 10 do Camera.CFrame = Camera.CFrame * CFrame.new(math.random(-2,2), math.random(-2,2), math.random(-2,2)); task.wait(0.05) end
            end)
            task.wait(0.5) 
            
            -- Check an toàn 100m phía trước
            local raycastParams = RaycastParams.new(); raycastParams.FilterDescendantsInstances = {char}; raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            local safeYRay = workspace:Raycast(targetPos + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), raycastParams)
            local finalPos = safeYRay and (safeYRay.Position + Vector3.new(0, hum.HipHeight + 3, 0)) or targetPos
            
            -- Cổng Dựng Đứng Đầu Ra
            local p2, a2 = SpawnFrontPortal(finalPos - dashDirection * 5, dashDirection, Color3.fromRGB(0, 255, 100))
            PlaySound(142070127, 0.8, 3)
            task.spawn(function() for i=1, 10 do StrikeLightning(p2.Position, 15, Color3.fromRGB(0, 255, 100)); task.wait(0.1) end end)
            
            -- Nhân vật ở trong cổng
            root.CFrame = p2.CFrame
            for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then v.Transparency = 0 end end
            
            -- Đi ra ngoài cổng
            TweenService:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = CFrame.new(finalPos, finalPos + dashDirection)}):Play()
            task.wait(0.5)
            
            p2:Destroy(); a2:Destroy(); blur:Destroy()
            hum.WalkSpeed = 50; isCasting = false
        end)
    end
})

