-- ==========================================
-- HÀM HỖ TRỢ VFX & AUDIO
-- ==========================================
local function PlaySound(id, pitch, vol, parent)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = vol or 2; s.Pitch = pitch or 1; s.Parent = parent or (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) or workspace
    s:Play(); Debris:AddItem(s, 5)
end

-- Tàn ảnh
local function CreateGhostTrail(char, duration, color)
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = part:Clone()
            clone.Parent = workspace; clone.Anchored = true; clone.CanCollide = false
            clone.Material = Enum.Material.ForceField; clone.Color = color or Color3.fromRGB(150, 255, 255)
            for _, v in pairs(clone:GetChildren()) do if not v:IsA("SpecialMesh") then v:Destroy() end end
            TweenService:Create(clone, TweenInfo.new(duration or 0.5), {Transparency = 1}):Play()
            Debris:AddItem(clone, duration or 0.5)
        end
    end
end

-- Gợn sóng dạng vòng rỗng (Torus Mesh) siêu to khổng lồ
local function CreateRingRipple(pos)
    for i = 1, 3 do
        task.spawn(function()
            local ring = Instance.new("Part", workspace)
            ring.Anchored = true; ring.CanCollide = false
            ring.Material = Enum.Material.Neon; ring.Color = Color3.new(1, 1, 1)
            ring.CFrame = CFrame.new(pos)
            
            -- Ép Mesh vòng rỗng vào
            local mesh = Instance.new("SpecialMesh", ring)
            mesh.MeshId = "rbxassetid://3270017" -- ID Vòng tròn rỗng
            mesh.Scale = Vector3.new(1, 0.1, 1)
            
            -- Phóng to x5 lần, mờ dần
            local tw = TweenService:Create(mesh, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Scale = Vector3.new(200, 0.1, 200) -- Gấp 5 lần cái cũ
            })
            local twPart = TweenService:Create(ring, TweenInfo.new(0.8), {Transparency = 0.8}) -- Không trắng lóa, mờ mờ tí
            
            tw:Play(); twPart:Play()
            Debris:AddItem(ring, 0.8)
        end)
        task.wait(0.2)
    end
end

-- Tia sét ngẫu nhiên
local function StrikeLightning(center, radius, color)
    local p1 = center + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    local p2 = center + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    local dist = (p1 - p2).Magnitude
    local bolt = Instance.new("Part", workspace)
    bolt.Size = Vector3.new(0.5, 0.5, dist); bolt.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -dist/2)
    bolt.Anchored = true; bolt.CanCollide = false; bolt.Material = Enum.Material.Neon; bolt.Color = color or Color3.fromRGB(255, 50, 50)
    Debris:AddItem(bolt, 0.1)
end

-- ==========================================
-- 1. BIẾN HÌNH MA THẦN (BẢN CHÁY MÁY)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: 🔮 Ấn Ký Ma Thần",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "🔮 Ấn Ký Ma Thần", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            if _G.IsMaThan then return end
            _G.IsMaThan = true
            
            for _, anim in pairs(hum:GetPlayingAnimationTracks()) do anim:Stop() end
            
            PlaySound(142070127, 0.4, 3); PlaySound(178452221, 0.5, 2); PlaySound(2248511, 0.2, 1.5)
            
            local cc = Instance.new("ColorCorrectionEffect", Lighting)
            cc.Name = "MaThanCC"
            TweenService:Create(cc, TweenInfo.new(1), {Saturation = -1, Contrast = 0.2, TintColor = Color3.fromRGB(200, 200, 200)}):Play()
            
            -- Vụ nổ sóng âm khổng lồ lúc biến hình
            local blast = Instance.new("Part", workspace)
            blast.Shape = Enum.PartType.Ball; blast.Size = Vector3.new(1,1,1); blast.CFrame = root.CFrame
            blast.Anchored = true; blast.CanCollide = false; blast.Material = Enum.Material.ForceField; blast.Color = Color3.new(1,0,0)
            TweenService:Create(blast, TweenInfo.new(1), {Size = Vector3.new(200,200,200), Transparency = 1}):Play()
            Debris:AddItem(blast, 1)
            
            root.Anchored = true
            local twTransform = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Exponential), {CFrame = root.CFrame * CFrame.new(0, 8, 0) * CFrame.Angles(0, math.rad(360*2), 0)})
            twTransform:Play(); twTransform.Completed:Wait()
            root.Anchored = false
            
            hum.HipHeight = 5; hum.WalkSpeed = 50 
            
            -- Aura Tỏa Ra (Rất nhiều)
            local auraWhite = Instance.new("ParticleEmitter", root)
            auraWhite.Name = "V4AuraWhite"; auraWhite.Texture = "rbxassetid://504653048" 
            auraWhite.Color = ColorSequence.new(Color3.new(1, 1, 1)); auraWhite.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.5, 15), NumberSequenceKeypoint.new(1, 0)})
            auraWhite.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.5, 0.2), NumberSequenceKeypoint.new(1, 1)})
            auraWhite.Lifetime = NumberRange.new(1.5); auraWhite.Rate = 50; auraWhite.Speed = NumberRange.new(0)
            auraWhite.Rotation = NumberRange.new(0, 360); auraWhite.RotSpeed = NumberRange.new(-100, 100); auraWhite.LockedToPart = true
            
            local auraBlack = Instance.new("ParticleEmitter", root)
            auraBlack.Name = "V4AuraBlack"; auraBlack.Texture = "rbxassetid://243660364"
            auraBlack.Color = ColorSequence.new(Color3.new(0, 0, 0)); auraBlack.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 5), NumberSequenceKeypoint.new(1, 10)})
            auraBlack.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
            auraBlack.Lifetime = NumberRange.new(0.5, 1); auraBlack.Rate = 150; auraBlack.Speed = NumberRange.new(5, 10)
            auraBlack.SpreadAngle = Vector2.new(360, 360)
            
            -- Vòng lặp Sét giật liên tục + Tàn ảnh
            local timer = 0
            ghostMovementConn = RunService.RenderStepped:Connect(function(dt)
                timer = timer + dt
                if timer > 0.1 then
                    if hum.MoveDirection.Magnitude > 0 then CreateGhostTrail(char, 0.6, Color3.fromRGB(150, 150, 150)) end
                    if math.random(1, 10) == 1 then StrikeLightning(root.Position, 30, Color3.fromRGB(255, 0, 50)) end
                    timer = 0 
                end
            end)
        end)
    end
})

-- ==========================================
-- 2. BƯỚC NHẢY KHÔNG GIAN (GỢN SÓNG VÒNG RỖNG)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: ⚡ Bước Nhảy Không Gian",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "⚡ Bước Nhảy Không Gian", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            if not _G.IsMaThan then return end
            
            local root = char.HumanoidRootPart
            PlaySound(231917744, 0.8, 2); PlaySound(12222208, 1.5, 1)  
            
            local startPos = root.Position
            local dashVector = root.CFrame.LookVector * 50
            local ray = workspace:Raycast(startPos, dashVector, RaycastParams.new())
            local targetPos = ray and ray.Position or (startPos + dashVector)
            local actualDist = (targetPos - startPos).Magnitude
            
            TweenService:Create(Camera, TweenInfo.new(0.1, Enum.EasingStyle.Exponential), {FieldOfView = 110}):Play()
            
            local beam = Instance.new("Part", workspace)
            beam.Size = Vector3.new(3, 3, actualDist); beam.CFrame = CFrame.lookAt(startPos, targetPos) * CFrame.new(0, 0, -actualDist/2)
            beam.Anchored = true; beam.CanCollide = false; beam.Material = Enum.Material.Neon; beam.Color = Color3.new(1, 1, 1)
            TweenService:Create(beam, TweenInfo.new(0.3), {Size = Vector3.new(0,0,actualDist), Transparency = 1}):Play()
            Debris:AddItem(beam, 0.3)
            
            local tw = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos, targetPos + dashVector)})
            tw:Play()
            
            task.spawn(function()
                while tw.PlaybackState == Enum.PlaybackState.Playing do
                    CreateGhostTrail(char, 0.3, Color3.new(1,1,1)); task.wait(0.01)
                end
            end)
            
            tw.Completed:Wait()
            TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {FieldOfView = 70}):Play()
            
            -- GỌI GỢN SÓNG VÒNG RỖNG X5
            CreateRingRipple(root.Position - Vector3.new(0, 4, 0)) 
        end)
    end
})

-- ==========================================
-- 3. CỔNG KHÔNG GIAN (ĐI VÀ VỀ)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: 🌀 Cổng Không Gian Xanh",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "🌀 Cổng Không Gian", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            if not _G.IsMaThan then return end
            
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            if not _G.InPortalRealm then
                -- TRẠNG THÁI 1: BƯỚC VÀO CỔNG
                _G.InPortalRealm = true
                _G.PortalSavedPos = root.CFrame -- Lưu tọa độ cũ
                
                -- Tạo cổng đen, viền xanh biển dưới đất
                local portal = Instance.new("Part", workspace)
                portal.Shape = Enum.PartType.Cylinder; portal.Size = Vector3.new(0.5, 10, 10)
                portal.CFrame = root.CFrame * CFrame.new(0, -hum.HipHeight - 2, 0) * CFrame.Angles(0, 0, math.rad(90))
                portal.Anchored = true; portal.CanCollide = false; portal.Material = Enum.Material.Neon; portal.Color = Color3.fromRGB(0, 0, 0)
                
                local portalAura = Instance.new("Part", workspace)
                portalAura.Shape = Enum.PartType.Cylinder; portalAura.Size = Vector3.new(0.4, 11, 11)
                portalAura.CFrame = portal.CFrame
                portalAura.Anchored = true; portalAura.CanCollide = false; portalAura.Material = Enum.Material.Neon; portalAura.Color = Color3.fromRGB(0, 150, 255)
                
                PlaySound(142070127, 0.5, 3)
                
                -- Animation chìm xuống đất (Tắt va chạm mới chìm được nha má)
                hum.WalkSpeed = 0
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
                
                local twDown = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Sine), {CFrame = root.CFrame * CFrame.new(0, -10, 0)})
                twDown:Play()
                
                -- Sấm sét giật tung tóe lúc chìm
                task.spawn(function()
                    for i = 1, 15 do StrikeLightning(portal.Position, 15, Color3.fromRGB(0, 150, 255)); task.wait(0.1) end
                end)
                
                twDown.Completed:Wait()
                portal:Destroy(); portalAura:Destroy()
                
                -- Dịch chuyển lên Realm (Trên trời 10000m)
                root.CFrame = CFrame.new(0, 10000, 0)
                local floor = Instance.new("Part", workspace)
                floor.Name = "PortalFloor"; floor.Size = Vector3.new(100, 1, 100); floor.CFrame = CFrame.new(0, 9995, 0)
                floor.Anchored = true; floor.Material = Enum.Material.ForceField; floor.Color = Color3.fromRGB(0, 50, 100)
                
                -- Phục hồi va chạm và cho di chuyển
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end
                hum.WalkSpeed = 50
                
                -- Màn hình mờ ảo tung chảo + Đổi màu xanh
                if Lighting:FindFirstChild("MaThanCC") then Lighting.MaThanCC.TintColor = Color3.fromRGB(100, 200, 255) end
                local blur = Instance.new("BlurEffect", Lighting)
                blur.Name = "PortalBlur"; blur.Size = 30 -- Mờ ơi là mờ
                
                -- Sét xanh nổ liên tục trong Realm
                realmConn = RunService.RenderStepped:Connect(function()
                    if math.random(1, 5) == 1 then StrikeLightning(root.Position, 50, Color3.fromRGB(0, 200, 255)) end
                end)
                
            else
                -- TRẠNG THÁI 2: TRỞ VỀ TỪ CỔNG
                _G.InPortalRealm = false
                hum.WalkSpeed = 0
                
                -- Thu hồi Realm
                if realmConn then realmConn:Disconnect() end
                if workspace:FindFirstChild("PortalFloor") then workspace.PortalFloor:Destroy() end
                if Lighting:FindFirstChild("PortalBlur") then Lighting.PortalBlur:Destroy() end
                if Lighting:FindFirstChild("MaThanCC") then Lighting.MaThanCC.TintColor = Color3.fromRGB(200, 200, 200) end
                
                -- Về lại vị trí cũ, nằm dưới lòng đất 10m
                root.CFrame = _G.PortalSavedPos * CFrame.new(0, -10, 0)
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
                
                -- Mở cổng tại vị trí về
                local portal = Instance.new("Part", workspace)
                portal.Shape = Enum.PartType.Cylinder; portal.Size = Vector3.new(0.5, 10, 10)
                portal.CFrame = _G.PortalSavedPos * CFrame.new(0, -hum.HipHeight - 2, 0) * CFrame.Angles(0, 0, math.rad(90))
                portal.Anchored = true; portal.CanCollide = false; portal.Material = Enum.Material.Neon; portal.Color = Color3.fromRGB(0, 0, 0)
                
                local portalAura = Instance.new("Part", workspace)
                portalAura.Shape = Enum.PartType.Cylinder; portalAura.Size = Vector3.new(0.4, 11, 11)
                portalAura.CFrame = portal.CFrame
                portalAura.Anchored = true; portalAura.CanCollide = false; portalAura.Material = Enum.Material.Neon; portalAura.Color = Color3.fromRGB(0, 150, 255)
                
                PlaySound(142070127, 0.6, 3)
                
                -- Màn hình hơi mờ nhẹ lúc ngoi lên
                local tempBlur = Instance.new("BlurEffect", Lighting); tempBlur.Size = 15
                
                -- Tween ngoi đầu từ từ lên
                local twUp = TweenService:Create(root, TweenInfo.new(2, Enum.EasingStyle.Sine), {CFrame = _G.PortalSavedPos})
                twUp:Play()
                
                task.spawn(function()
                    for i = 1, 20 do StrikeLightning(portal.Position, 15, Color3.fromRGB(0, 150, 255)); task.wait(0.1) end
                end)
                
                twUp.Completed:Wait()
                portal:Destroy(); portalAura:Destroy(); tempBlur:Destroy()
                
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end
                hum.WalkSpeed = 50
            end
        end)
    end
})

-- ==========================================
-- 4. HỦY DẠNG
-- ==========================================
TabTrans:CreateButton({
    Name = "❌ Hủy Dạng Ma Thần",
    Callback = function()
        _G.IsMaThan = false
        _G.InPortalRealm = false
        local char = player.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum then hum.WalkSpeed = 16; hum.HipHeight = 0 end
            if root then 
                if root:FindFirstChild("V4AuraWhite") then root.V4AuraWhite:Destroy() end
                if root:FindFirstChild("V4AuraBlack") then root.V4AuraBlack:Destroy() end
            end
        end
        if ghostMovementConn then ghostMovementConn:Disconnect() end
        if realmConn then realmConn:Disconnect() end
        if Lighting:FindFirstChild("MaThanCC") then Lighting.MaThanCC:Destroy() end
        if Lighting:FindFirstChild("PortalBlur") then Lighting.PortalBlur:Destroy() end
        if workspace:FindFirstChild("PortalFloor") then workspace.PortalFloor:Destroy() end
    end
})
