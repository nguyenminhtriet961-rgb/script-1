-- ==========================================
-- HÀM HỖ TRỢ VFX & AUDIO
-- ==========================================
local function PlaySound(id, pitch, vol, parent)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = vol or 2; s.Pitch = pitch or 1; s.Parent = parent or (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) or workspace
    s:Play(); Debris:AddItem(s, 5)
end

-- Tàn ảnh
local function CreateGhostTrail(char, duration, color)
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = part:Clone()
            clone.Parent = workspace; clone.Anchored = true; clone.CanCollide = false
            clone.Material = Enum.Material.ForceField; clone.Color = color or Color3.fromRGB(150, 255, 255)
            for _, v in pairs(clone:GetChildren()) do if not v:IsA("SpecialMesh") then v:Destroy() end end
            TweenService:Create(clone, TweenInfo.new(duration or 0.5), {Transparency = 1}):Play()
            Debris:AddItem(clone, duration or 0.5)
        end
    end
end

-- Tia sét ngẫu nhiên
local function StrikeLightning(center, radius, color)
    local p1 = center + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    local p2 = center + Vector3.new(math.random(-radius, radius), math.random(-radius, radius), math.random(-radius, radius))
    local dist = (p1 - p2).Magnitude
    local bolt = Instance.new("Part", workspace)
    bolt.Size = Vector3.new(0.5, 0.5, dist); bolt.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -dist/2)
    bolt.Anchored = true; bolt.CanCollide = false; bolt.Material = Enum.Material.Neon; bolt.Color = color or Color3.fromRGB(0, 150, 255)
    Debris:AddItem(bolt, 0.1)
end

-- Gợn sóng vòng rỗng (Torus) siêu to
local function CreateRingRipple(pos)
    for i = 1, 3 do
        task.spawn(function()
            local ring = Instance.new("Part", workspace)
            ring.Anchored = true; ring.CanCollide = false
            ring.Transparency = 0.3; ring.Material = Enum.Material.Neon
            ring.Color = Color3.fromRGB(200, 255, 255)
            
            -- Xoay ngang mặt đất và dâng lên tí để không bị cắm xuống đất
            ring.CFrame = CFrame.new(pos) * CFrame.new(0, 0.5, 0) * CFrame.Angles(math.rad(90), 0, 0)
            
            -- Ép Mesh nhẫn (Torus)
            local mesh = Instance.new("SpecialMesh", ring)
            mesh.MeshId = "rbxassetid://3270017" 
            mesh.Scale = Vector3.new(10, 10, 0.1) -- Vòng siêu mỏng
            
            -- Tween lan rộng gấp 5 lần và mờ dần
            local twMesh = TweenService:Create(mesh, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Scale = Vector3.new(150, 150, 0.1)
            })
            local twTrans = TweenService:Create(ring, TweenInfo.new(0.8), {Transparency = 1})
            
            twMesh:Play(); twTrans:Play()
            Debris:AddItem(ring, 0.8)
        end)
        task.wait(0.2)
    end
end

-- Tạo Cổng Không Gian
local function SpawnPortal(cframe, color)
    local portal = Instance.new("Part", workspace)
    portal.Shape = Enum.PartType.Cylinder; portal.Size = Vector3.new(0.1, 12, 12)
    portal.CFrame = cframe * CFrame.Angles(0, 0, math.rad(90))
    portal.Anchored = true; portal.CanCollide = false
    portal.Material = Enum.Material.Neon; portal.Color = Color3.new(0,0,0)
    
    local aura = Instance.new("Part", workspace)
    aura.Shape = Enum.PartType.Cylinder; aura.Size = Vector3.new(0.05, 13, 13)
    aura.CFrame = portal.CFrame
    aura.Anchored = true; aura.CanCollide = false
    aura.Material = Enum.Material.Neon; aura.Color = color or Color3.fromRGB(0, 150, 255)
    
    return portal, aura
end

