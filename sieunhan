-- 4. BƯỚC NHẢY KHÔNG GIAN
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: ⚡ Bước Nhảy Không Gian",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "⚡ Bước Nhảy", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") or not _G.IsMaThan then return end
            
            local root = char.HumanoidRootPart
            PlaySound(231917744, 0.8, 2)
            
            local targetPos = mouse.Hit and mouse.Hit.Position or (root.Position + root.CFrame.LookVector * 50)
            local direction = (targetPos - root.Position)
            if direction.Magnitude > 50 then direction = direction.Unit * 50 end
            targetPos = root.Position + direction
            
            local actualDist = math.max((targetPos - root.Position).Magnitude, 0.1)
            TweenService:Create(Camera, TweenInfo.new(0.1, Enum.EasingStyle.Exponential), {FieldOfView = 110}):Play()
            
            local beam = Instance.new("Part", workspace)
            beam.Size = Vector3.new(2, 2, actualDist); beam.CFrame = CFrame.lookAt(root.Position, targetPos) * CFrame.new(0, 0, -actualDist/2)
            beam.Anchored = true; beam.CanCollide = false; beam.Material = Enum.Material.Neon; beam.Color = Color3.fromRGB(200, 255, 255)
            TweenService:Create(beam, TweenInfo.new(0.3), {Size = Vector3.new(0,0,actualDist), Transparency = 1}):Play(); Debris:AddItem(beam, 0.3)
            
            local tw = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.lookAt(targetPos, targetPos + direction)})
            tw:Play()
            task.spawn(function() while tw.PlaybackState == Enum.PlaybackState.Playing do CreateGhostTrail(char, 0.3, Color3.new(1,1,1)); task.wait(0.01) end end)
            tw.Completed:Wait()
            
            TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {FieldOfView = 70}):Play()
            CreateRingRipple(root.Position - Vector3.new(0, 4, 0)) 
        end)
    end
})

