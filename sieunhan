-- 2. BƯỚC NHẢY KHÔNG GIAN (LƯỚT THE THE FLASH)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: ⚡ Bước Nhảy Không Gian",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "⚡ Bước Nhảy Không Gian", false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            if not _G.IsMaThan then return end
            
            local root = char.HumanoidRootPart
            PlaySound(231917744, 0.8, 2)
            
            local targetPos = mouse.Hit.Position
            local direction = (targetPos - root.Position)
            if direction.Magnitude > 50 then direction = direction.Unit * 50 end
            targetPos = root.Position + direction
            
            local actualDist = (targetPos - root.Position).Magnitude
            TweenService:Create(Camera, TweenInfo.new(0.1, Enum.EasingStyle.Exponential), {FieldOfView = 110}):Play()
            
            local beam = Instance.new("Part", workspace)
            beam.Size = Vector3.new(2, 2, actualDist); beam.CFrame = CFrame.lookAt(root.Position, targetPos) * CFrame.new(0, 0, -actualDist/2)
            beam.Anchored = true; beam.CanCollide = false; beam.Material = Enum.Material.Neon; beam.Color = Color3.fromRGB(200, 255, 255)
            TweenService:Create(beam, TweenInfo.new(0.3), {Size = Vector3.new(0,0,actualDist), Transparency = 1}):Play()
            Debris:AddItem(beam, 0.3)
            
            local tw = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.lookAt(targetPos, targetPos + direction)})
            tw:Play()
            
            task.spawn(function()
                while tw.PlaybackState == Enum.PlaybackState.Playing do
                    CreateGhostTrail(char, 0.3, Color3.new(1,1,1)); task.wait(0.01)
                end
            end)
            
            tw.Completed:Wait()
            TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {FieldOfView = 70}):Play()
            
            -- TẠO VÒNG TRÒN RỖNG LAN TỎA
            CreateRingRipple(root.Position - Vector3.new(0, 4, 0)) 
        end)
    end
})

-- ==========================================
-- 3. CỔNG KHÔNG GIAN SÁT THỦ (TỰ ĐỘNG BƯỚC VÀO)
-- ==========================================
TabTrans:CreateButton({
    Name = "Nhận: 🌀 Cổng Sát Thủ Xuyên Không",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "🌀 Cổng Không Gian", false
        local isCasting = false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") or isCasting then return end
            if not _G.IsMaThan then return end
            
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            -- Tìm mục tiêu gần nhất
            local target = nil; local minDist = 300
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist < minDist then minDist = dist; target = p.Character.HumanoidRootPart end
                end
            end
            
            if not target then
                Rayfield:Notify({Title = "Thất bại", Content = "Không có ai ở gần để mở cổng!", Duration = 2})
                return
            end
            
            isCasting = true
            PlaySound(142070127, 0.5, 3)
            
            -- Cổng 1: Hiện trước mặt
            local portal1CF = root.CFrame * CFrame.new(0, -2, -6)
            local p1, a1 = SpawnPortal(portal1CF, Color3.fromRGB(0, 150, 255))
            
            -- Xả sét xanh quanh cổng
            task.spawn(function()
                for i=1, 10 do StrikeLightning(p1.Position, 15, Color3.fromRGB(0, 150, 255)); task.wait(0.1) end
            end)
            
            -- Animation tự đi vào cổng (Cutscene bằng Tween)
            hum.WalkSpeed = 0 -- Khóa tay người chơi
            local twIn = TweenService:Create(root, TweenInfo.new(0.6, Enum.EasingStyle.Linear), {CFrame = portal1CF})
            twIn:Play(); twIn.Completed:Wait()
            
            -- Biến mất
            for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.Transparency = 1 end end
            p1:Destroy(); a1:Destroy()
            
            -- Màn hình mờ siêu ảo
            local blur = Instance.new("BlurEffect", Lighting); blur.Size = 30
            task.wait(0.5) -- Delay trong không gian
            
            -- Cổng 2: Hiện sau lưng Target
            local portal2CF = target.CFrame * CFrame.new(0, -2, 6) * CFrame.Angles(0, math.rad(180), 0)
            local p2, a2 = SpawnPortal(portal2CF, Color3.fromRGB(0, 150, 255))
            PlaySound(142070127, 0.8, 3)
            
            task.spawn(function()
                for i=1, 10 do StrikeLightning(p2.Position, 15, Color3.fromRGB(0, 150, 255)); task.wait(0.1) end
            end)
            
            -- Đặt character vào cổng 2 và hiện lại
            root.CFrame = portal2CF
            for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then v.Transparency = 0 end end
            
            -- Animation bước ra
            local twOut = TweenService:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = target.CFrame * CFrame.new(0, 0, 3)})
            twOut:Play(); twOut.Completed:Wait()
            
            p2:Destroy(); a2:Destroy(); blur:Destroy()
            hum.WalkSpeed = 50 -- Mở khóa
            isCasting = false
        end)
    end
})

