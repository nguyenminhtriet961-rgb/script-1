TabTrans:CreateButton({
    Name = "Nhận: 👻 U Bộ Xuyên Tường",
    Callback = function()
        local tool = Instance.new("Tool", player.Backpack)
        tool.Name, tool.RequiresHandle = "👻 U Bộ Xuyên Tường", false
        local isPhasing = false
        
        tool.Activated:Connect(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") or isPhasing then return end
            if not _G.IsMaThan then 
                Rayfield:Notify({Title = "Cảnh báo", Content = "Phải hóa Ma Thần mới xuyên tường được!", Duration = 2})
                return 
            end
            
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            -- Phóng tia check tường
            local raycastParams = RaycastParams.new(); raycastParams.FilterDescendantsInstances = {char}; raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            local result = workspace:Raycast(root.Position, root.CFrame.LookVector * 5, raycastParams)
            
            if not result then 
                Rayfield:Notify({Title = "Lỗi U Bộ", Content = "Phải đứng sát vào tường mới chui qua được!", Duration = 2})
                return 
            end
            
            isPhasing = true
            hum.WalkSpeed = 0 
            PlaySound(231917744, 0.3, 2) 
            
            local oldProps = {}
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then
                    oldProps[v] = {Mat = v.Material, Col = v.Color, Trans = v.Transparency, CanCol = v.CanCollide}
                    v.Material = Enum.Material.ForceField; v.Color = Color3.new(0, 0, 0); v.Transparency = 0.5; v.CanCollide = false
                end
            end
            
            local tw = TweenService:Create(root, TweenInfo.new(2.5, Enum.EasingStyle.Linear), {CFrame = root.CFrame * CFrame.new(0, 0, -10)})
            tw:Play()
            
            task.spawn(function()
                while tw.PlaybackState == Enum.PlaybackState.Playing do
                    CreateGhostTrail(char, 0.8, Color3.fromRGB(50, 50, 50)); task.wait(0.1)
                end
            end)
            
            tw.Completed:Wait()
            
            for v, props in pairs(oldProps) do
                if v and v.Parent then
                    v.Material = props.Mat; v.Color = props.Col; v.Transparency = props.Trans; v.CanCollide = true
                end
            end
            
            hum.WalkSpeed = 50 
            isPhasing = false
        end)
    end
})

